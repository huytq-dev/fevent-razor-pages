@page
@model UI.Pages.LoginModel
@{
    ViewData["Title"] = "FEvents Login - FPT University";
    Layout = null;
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&amp;family=Noto+Sans:wght@100..900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f96706",
                        "background-light": "#f8f7f5",
                        "background-dark": "#23170f",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center">
<div class="flex w-full min-h-screen">
<!-- Left Side: Hero Image Section -->
<div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-primary items-center justify-center p-12">
<div class="absolute inset-0 z-0">
<div class="absolute inset-0 bg-primary/40 mix-blend-multiply z-10"></div>
<div class="w-full h-full bg-center bg-no-repeat bg-cover" data-alt="Scenic view of modern FPT University campus architecture with greenery" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAimiTMCYAqmttfrcVh6_f1ZLNj8CtQxUXUYSNAd-8eNT4zcPCqzkBYWslPUZhdCifvfvqHYEXNekiY5krQdnXNQ__SRVPy3z7VNnm1IRIepE1LxTStVJNhH84lM1RMUhtyF5QASZsfUYF_5pNbF5zLXQupFuC3jLm6pDnZv97oDhOGR8DBbjyULjGDbENBjdaHOf9ff5EngY7k-Nh_537-4f1DotOJC6UHY6JkYlYNxHuJI4xT0s1-J3E09J-l2gfo0bFzQhCc8h71");'>
</div>
</div>
<div class="relative z-20 max-w-lg text-white">
<div class="mb-8 flex items-center gap-2">
<span class="material-symbols-outlined text-4xl">event_upcoming</span>
<span class="text-3xl font-black tracking-tight">FEvents</span>
</div>
<h1 class="text-5xl font-black leading-tight tracking-[-0.033em] mb-6">
                    Connect. Organize. Experience.
                </h1>
<p class="text-lg font-light opacity-90 leading-relaxed">
                    The central hub for all FPT University events. Join workshops, competitions, and student club activities with just one click.
                </p>
<div class="mt-12 flex gap-4">
<div class="flex flex-col">
<span class="text-2xl font-bold">500+</span>
<span class="text-sm opacity-80 uppercase tracking-wider">Events</span>
</div>
<div class="w-[1px] bg-white/30"></div>
<div class="flex flex-col">
<span class="text-2xl font-bold">10k+</span>
<span class="text-sm opacity-80 uppercase tracking-wider">Students</span>
</div>
</div>
</div>
</div>
<!-- Right Side: Login Form -->
<div class="w-full lg:w-1/2 flex flex-col justify-center items-center p-8 bg-background-light dark:bg-background-dark">
<div class="w-full max-w-[480px] flex flex-col gap-8">
<!-- Brand Header for Mobile -->
<div class="lg:hidden flex items-center gap-2 mb-4">
    <span class="material-symbols-outlined text-primary text-3xl">event_upcoming</span>
    <span class="text-2xl font-black tracking-tight text-[#1c130d] dark:text-white">FEvents</span>
</div>
<div class="flex flex-col gap-2">
    <h2 class="text-[#1c130d] dark:text-white text-3xl font-black leading-tight tracking-[-0.033em] lg:text-4xl">
        Welcome back
    </h2>
    <p class="text-[#9e6a47] dark:text-gray-400 text-base font-normal">
        Please enter your details or use your university account.
    </p>
</div>
<!-- Primary SSO Button -->
<div class="flex flex-col gap-4">
    <button class="flex w-full cursor-pointer items-center justify-center gap-3 overflow-hidden rounded-lg h-12 px-5 bg-primary text-white text-base font-bold transition-transform hover:scale-[1.01] active:scale-[0.99]">
        <img alt="Google Logo" class="w-5 h-5 bg-white rounded-full p-0.5" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDf6Ug4v_bBDB7NORNdA4CYtuY9ie9loEFRnTvgyZJQ-GOIOrtbFzCREos9V6bDmRbtF7oq2k7HToKeHE-w4uRAqYXW7dM4awUH7PxkPmv4HxEjqgXXfcg71KcJfgwj2O80pTvA5tcPbEPFFRUt5td54Fi40jWwit7u73WjOZ-g72CQ9Hg8sSgx7h6XqF4_AAsGKeTUw4NAleJXh9-jQ7C5ABUD4yQueHgMCGYommrzZp-ueRtFE4jYavrggYBgXJ01b72k6FtZbXOC" />
        <span>Login with FPT Email</span>
    </button>
    <div class="flex items-center gap-4 py-2">
        <div class="h-px bg-[#e9d9ce] dark:bg-gray-700 flex-1"></div>
        <span class="text-[#9e6a47] dark:text-gray-500 text-sm font-medium uppercase tracking-wider">or login with email</span>
        <div class="h-px bg-[#e9d9ce] dark:bg-gray-700 flex-1"></div>
    </div>
</div>
<!-- Manual Login Form -->
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded mb-2">
        @Model.ErrorMessage
    </div>
}
<form method="post" class="flex flex-col gap-4">
    <div class="flex flex-col gap-1.5">
        <label class="text-[#1c130d] dark:text-gray-200 text-sm font-semibold">University Email</label>
        <div class="relative">
            <input asp-for="Email" class="form-input flex w-full rounded-lg text-[#1c130d] dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/20 border border-[#e9d9ce] dark:border-gray-700 bg-white dark:bg-gray-800 h-14 placeholder:text-[#9e6a47]/50 p-[15px] text-base font-normal" placeholder="student@fpt.edu.vn" type="email" />
        </div>
    </div>
    <div class="flex flex-col gap-1.5">
        <label class="text-[#1c130d] dark:text-gray-200 text-sm font-semibold">Password</label>
        <div class="flex w-full items-stretch rounded-lg border border-[#e9d9ce] dark:border-gray-700 bg-white dark:bg-gray-800 focus-within:ring-2 focus-within:ring-primary/20">
            <input asp-for="Password" class="form-input flex w-full border-0 bg-transparent h-14 placeholder:text-[#9e6a47]/50 p-[15px] text-[#1c130d] dark:text-white text-base font-normal focus:ring-0" placeholder="Enter your password" type="password" />
            <button class="text-[#9e6a47] dark:text-gray-400 px-4 hover:text-primary transition-colors" type="button">
                <span class="material-symbols-outlined">visibility</span>
            </button>
        </div>
    </div>
    <div class="flex items-center justify-between">
        <label class="flex items-center gap-2 cursor-pointer group">
            <input asp-for="RememberMe" class="rounded border-[#e9d9ce] text-primary focus:ring-primary w-4 h-4" type="checkbox" />
            <span class="text-sm text-[#1c130d] dark:text-gray-300 font-medium group-hover:text-primary transition-colors">Remember me</span>
        </label>
        <a class="text-primary text-sm font-bold hover:underline" href="#">Forgot Password?</a>
    </div>
    <button class="mt-4 flex w-full items-center justify-center rounded-lg h-14 bg-[#1c130d] dark:bg-primary text-white text-base font-bold hover:opacity-90 transition-opacity" type="submit">
        Sign In
    </button>
</form>
<!-- Footer Sign Up -->
<div class="text-center">
<p class="text-[#9e6a47] dark:text-gray-400 text-sm">
                        Don't have an account yet? 
                        <a class="text-primary font-bold hover:underline ml-1" href="#">Create an account</a>
</p>
</div>
<!-- Bottom Meta -->
<div class="mt-8 pt-8 border-t border-[#e9d9ce] dark:border-gray-800">
<div class="flex justify-center gap-6">
<a class="text-[#9e6a47] text-xs hover:text-primary transition-colors" href="#">Privacy Policy</a>
<a class="text-[#9e6a47] text-xs hover:text-primary transition-colors" href="#">Terms of Service</a>
<a class="text-[#9e6a47] text-xs hover:text-primary transition-colors" href="#">Contact Support</a>
</div>
<p class="text-center text-[#9e6a47] text-[10px] mt-4 opacity-50 uppercase tracking-widest">
                        © 2024 FPT University Event Management System
                    </p>
</div>
</div>
</div>
</div>
</body></html>