@page
@model UI.Pages.SignUpModel
@{
    ViewData["Title"] = "FEvents - Sign Up";
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d7ff2",
                        "fpt-orange": "#F27124",
                        "fpt-green": "#40b549",
                        "background-light": "#f3f4f6", 
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    boxShadow: {
                        'glow': '0 0 20px rgba(242, 112, 36, 0.15)',
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Lexend', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .filled-icon { font-variation-settings: 'FILL' 1; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-white dark:bg-background-dark min-h-screen text-[#111418] dark:text-white relative selection:bg-fpt-orange selection:text-white overflow-hidden">
<div class="flex h-screen w-full">
    <div class="hidden lg:flex relative w-1/2 bg-gray-900 items-end justify-start overflow-hidden group">
        <img alt="FPT University Campus" class="absolute inset-0 w-full h-full object-cover object-center opacity-90 transition-transform duration-1000 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqNNUcMI7LMQ1X2T-nZNvE7gyO_yfhDxg1V6HKyA078xR1CLu-7bYi6Ljt67J5bPqonYfuHu59rwNY3vLuNgHcE2nB7jITXrWeXtnAcxmJEJpCKcroMAosTrea_3Tvy3J5jXCGnbMi5vr5KqRjN0KtnhmcPqxYTpCqXi_JLGTcM6kMaFKSy1_NSJQgDUoOoSmYHSFiTZnI4LGWBYGsOwzoIb1wBeKP71QCAGj0yZucoC_YuJv3RCU2y1WCw20-DGjAEQbpEjdSB3_v" />
        <div class="absolute inset-0 bg-gradient-to-tr from-fpt-orange/90 via-fpt-orange/40 to-transparent mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80"></div>
        <div class="absolute top-10 left-10 flex items-center gap-3 z-20">
            <div class="flex items-center justify-center size-10 rounded-lg bg-white/10 backdrop-blur-md shadow-sm text-white border border-white/20">
                <svg class="size-6" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path clip-rule="evenodd" d="M24 18.4228L42 11.475V34.3663C42 34.7796 41.7457 35.1504 41.3601 35.2992L24 42V18.4228Z" fill="#ffffff" fill-rule="evenodd"></path>
                    <path clip-rule="evenodd" d="M24 8.18819L33.4123 11.574L24 15.2071L14.5877 11.574L24 8.18819ZM9 15.8487L21 20.4805V37.6263L9 32.9945V15.8487ZM27 37.6263V20.4805L39 15.8487V32.9945L27 37.6263ZM25.354 2.29885C24.4788 1.98402 23.5212 1.98402 22.646 2.29885L4.98454 8.65208C3.7939 9.08038 3 10.2097 3 11.475V34.3663C3 36.0196 4.01719 37.5026 5.55962 38.098L22.9197 44.7987C23.6149 45.0671 24.3851 45.0671 25.0803 44.7987L42.4404 38.098C43.9828 37.5026 45 36.0196 45 34.3663V11.475C45 10.2097 44.2061 9.08038 43.0155 8.65208L25.354 2.29885Z" fill="currentColor" fill-rule="evenodd"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-white drop-shadow-md">FEvents</h2>
        </div>
        <div class="relative z-10 p-12 max-w-2xl">
            <h1 class="text-5xl font-black text-white mb-4 leading-tight tracking-tight drop-shadow-xl">
                Start Your Journey.
            </h1>
            <p class="text-lg text-white/90 font-medium max-w-md leading-relaxed drop-shadow-lg">
                Join the official event platform for FPT University. Create, explore, and connect with your campus community.
            </p>
        </div>
    </div>
    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center p-6 sm:p-12 xl:p-24 bg-white dark:bg-background-dark overflow-y-auto custom-scrollbar">
        <div class="w-full max-w-lg space-y-8">
            <div class="text-left space-y-2">
                <h2 class="text-3xl font-black tracking-tighter text-gray-900 dark:text-white">Create Your Account</h2>
                <p class="text-gray-500 dark:text-gray-400 font-medium">Please enter your details to sign up.</p>
            </div>
            <form method="post" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide ml-1">Full Name</label>
                        <input asp-for="FullName" class="w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 text-gray-900 dark:text-white placeholder:text-gray-400 focus:border-fpt-orange focus:ring-fpt-orange/20 transition-all font-medium text-sm" placeholder="Nguyen Van A" type="text" />
                        <span asp-validation-for="FullName" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide ml-1">Student ID (MSSV)</label>
                        <input asp-for="StudentId" class="w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 text-gray-900 dark:text-white placeholder:text-gray-400 focus:border-fpt-orange focus:ring-fpt-orange/20 transition-all font-medium text-sm" placeholder="SE123456" type="text" />
                        <span asp-validation-for="StudentId" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide ml-1">Major</label>
                        <div class="relative">
                            <select asp-for="Major" class="w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 text-gray-900 dark:text-white focus:border-fpt-orange focus:ring-fpt-orange/20 transition-all font-medium text-sm appearance-none px-4 cursor-pointer text-gray-500">
                                <option disabled selected value="">Select Major</option>
                                <option value="Software Engineering" class="text-gray-900">Software Engineering</option>
                                <option value="Artificial Intelligence" class="text-gray-900">Artificial Intelligence</option>
                                <option value="Graphic Design" class="text-gray-900">Graphic Design</option>
                                <option value="International Business" class="text-gray-900">International Business</option>
                                <option value="Digital Marketing" class="text-gray-900">Digital Marketing</option>
                                <option value="Information Assurance" class="text-gray-900">Information Assurance</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xl">expand_more</span>
                        </div>
                        <span asp-validation-for="Major" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide ml-1">FPT Email</label>
                        <input asp-for="Email" class="w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 text-gray-900 dark:text-white placeholder:text-gray-400 focus:border-fpt-orange focus:ring-fpt-orange/20 transition-all font-medium text-sm" placeholder="name@fpt.edu.vn" type="email" />
                        <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-gray-700 dark:text-gray-300 uppercase tracking-wide ml-1">Password</label>
                    <div class="relative">
                        <input asp-for="Password" id="passwordInput" class="w-full h-12 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 text-gray-900 dark:text-white placeholder:text-gray-400 focus:border-fpt-orange focus:ring-fpt-orange/20 transition-all font-medium text-sm pr-12" placeholder="Create a strong password" type="password" />
                        <button id="togglePasswordBtn" class="absolute right-3 top-1/2 -translate-y-1/2 p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors rounded-full hover:bg-gray-100 dark:hover:bg-gray-800" type="button">
                            <span class="material-symbols-outlined text-xl leading-none" id="togglePasswordIcon">visibility_off</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
                    <div class="flex items-center gap-1.5 pt-1 px-1">
                        <div id="strengthBar1" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-colors duration-300"></div>
                        <div id="strengthBar2" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-colors duration-300"></div>
                        <div id="strengthBar3" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-colors duration-300"></div>
                        <div id="strengthBar4" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-colors duration-300"></div>
                        <span id="strengthText" class="text-[10px] font-bold text-gray-400 ml-1 uppercase tracking-wider transition-colors duration-300">Weak</span>
                    </div>
                </div>
                <div class="flex flex-col gap-1">
                    <div class="flex items-start gap-3">
                        <input asp-for="AgreeTerms" class="mt-1 h-4 w-4 rounded border-gray-300 text-fpt-orange focus:ring-fpt-orange/20 cursor-pointer" id="terms" type="checkbox" />
                        <label class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed cursor-pointer select-none" for="terms">
                            I agree to FEvents <a class="text-fpt-orange hover:underline font-bold" href="#">Terms of Service</a> and <a class="text-fpt-orange hover:underline font-bold" href="#">Privacy Policy</a>.
                        </label>
                    </div>
                    <span asp-validation-for="AgreeTerms" class="text-xs text-red-500 block"></span>
                </div>
                <button type="submit" class="w-full py-4 px-6 bg-fpt-orange hover:bg-[#d65d1b] text-white font-bold rounded-xl shadow-[0_4px_14px_0_rgba(242,113,36,0.39)] hover:shadow-[0_6px_20px_rgba(242,113,36,0.23)] hover:-translate-y-0.5 transition-all duration-200 active:scale-[0.98]">
                    Register
                </button>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded-xl mt-2 font-medium text-sm">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }
            </form>
            <div class="text-center pt-2">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">
                    Already have an account? 
                    <a asp-page="/Login" class="text-fpt-orange hover:text-[#d65d1b] font-bold transition-colors ml-1">Log In</a>
                </p>
            </div>
        </div>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const passwordInput = document.getElementById("passwordInput");
        const toggleBtn = document.getElementById("togglePasswordBtn");
        const toggleIcon = document.getElementById("togglePasswordIcon");
        const bars = [
            document.getElementById("strengthBar1"),
            document.getElementById("strengthBar2"),
            document.getElementById("strengthBar3"),
            document.getElementById("strengthBar4")
        ];
        const strengthText = document.getElementById("strengthText");
        const conditions = [
            { regex: /.{8,}/, label: "At least 8 characters" },
            { regex: /[A-Z]/, label: "Uppercase letter" },
            { regex: /[a-z]/, label: "Lowercase letter" },
            { regex: /\d/, label: "Number" },
            { regex: /[^A-Za-z0-9]/, label: "Special character" }
        ];
        // Add condition list below password
        let condList = document.getElementById("passwordConditions");
        if (!condList) {
            condList = document.createElement("ul");
            condList.id = "passwordConditions";
            condList.className = "text-xs mt-2 mb-1 font-medium";
            passwordInput.parentElement.parentElement.appendChild(condList);
        }
        toggleBtn.addEventListener("click", function() {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);
            toggleIcon.textContent = type === "password" ? "visibility_off" : "visibility";
        });
        function updateStrengthMeter(password) {
            let strength = 0;
            let met = conditions.map(c => c.regex.test(password));
            strength = met.filter(Boolean).length;
            // Color logic: 4 màu cho 5 nấc
            let color = "bg-gray-200";
            if (strength <= 2) color = "bg-red-400";
            else if (strength === 3) color = "bg-yellow-400";
            else if (strength === 4) color = "bg-blue-400";
            else if (strength === 5) color = "bg-green-500";
            for (let i = 0; i < bars.length; i++) {
                bars[i].className = "h-1 flex-1 rounded-full transition-colors duration-300 " + (i < strength ? color : "bg-gray-200");
            }
            // Strength text: chỉ 4 màu
            let textColor = "text-red-400";
            if (strength === 3) textColor = "text-yellow-400";
            else if (strength === 4) textColor = "text-blue-400";
            else if (strength === 5) textColor = "text-green-500";
            strengthText.textContent = strength === 5 ? "STRONG" : strength >= 3 ? "MEDIUM" : "WEAK";
            strengthText.className = "text-[10px] font-bold ml-1 uppercase tracking-wider transition-colors duration-300 " + textColor;
            // Show conditions
            condList.innerHTML = conditions.map((c, idx) => `<li class="mb-1 flex items-center gap-1"><span class="material-symbols-outlined text-xs ${met[idx] ? 'text-green-500' : 'text-gray-400'}">${met[idx] ? 'check_circle' : 'cancel'}</span>${c.label}</li>`).join("");
        }
        passwordInput.addEventListener("input", function() {
            updateStrengthMeter(passwordInput.value);
        });
        updateStrengthMeter(passwordInput.value);
    });
</script>
</body>
</html>
