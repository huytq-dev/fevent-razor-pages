@page "/Management/EventDetail/{id:guid}"
@model UI.Pages.Management.EventDetailModel
@using Domain
@using System.Globalization
@{
    ViewData["Title"] = Model.Event?.Title ?? "Event Detail";
    Layout = null;
    var ev = Model.Event;
    var status = ev != null ? (EventStatus)ev.Status : EventStatus.Draft;

    var (statusLabel, statusBg, statusText) = status switch {
        EventStatus.Draft     => ("Draft",     "bg-gray-100 dark:bg-gray-800",   "text-gray-500 dark:text-gray-400"),
        EventStatus.Pending   => ("Pending Review", "bg-yellow-100 dark:bg-yellow-900/30", "text-yellow-700 dark:text-yellow-400"),
        EventStatus.Approved  => ("Approved",  "bg-green-100 dark:bg-green-900/30",  "text-green-700 dark:text-green-400"),
        EventStatus.Rejected  => ("Rejected",  "bg-red-100 dark:bg-red-900/30",   "text-red-700 dark:text-red-400"),
        EventStatus.Cancelled => ("Cancelled", "bg-gray-100 dark:bg-gray-800",   "text-gray-500 dark:text-gray-400"),
        EventStatus.Completed => ("Completed", "bg-blue-100 dark:bg-blue-900/30","text-blue-700 dark:text-blue-400"),
        _                     => ("Unknown",   "bg-gray-100 dark:bg-gray-800",   "text-gray-500 dark:text-gray-400"),
    };

    var canEdit   = status is EventStatus.Draft or EventStatus.Pending or EventStatus.Rejected;
    var canPublish = status is EventStatus.Draft or EventStatus.Pending or EventStatus.Rejected;
    var canCancel = status is EventStatus.Pending or EventStatus.Approved;
    var canDelete = status is EventStatus.Draft or EventStatus.Rejected or EventStatus.Cancelled;
    var canViewParticipants = status is EventStatus.Approved or EventStatus.Completed;

    var avatarUrl = Model.AvatarUrl
        ?? (Model.FullName is not null
            ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName)}&background=f96706&color=fff"
            : "");

    var registeredPct = ev != null && ev.MaxParticipants > 0
        ? Math.Min(100, (int)Math.Round((double)ev.RegisteredCount / ev.MaxParticipants * 100))
        : 0;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - FEvents</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f96706",
                        "background-light": "#f8f7f5",
                        "background-dark": "#23170f",
                    },
                    fontFamily: { "display": ["Lexend", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
</head>
<body class="font-display bg-background-light dark:bg-background-dark text-[#181411] dark:text-white min-h-screen">

    @* ── Header (same as CreateEvent) ─────────────────────────────── *@
    <header class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-[#e6dfdb] bg-white dark:bg-[#1a120b] dark:border-[#3e342f] px-10 py-3 shadow-sm">
        <div class="flex items-center gap-4 text-[#181411] dark:text-white">
            <div class="size-8 flex items-center justify-center rounded-lg bg-primary/10 text-primary">
                <span class="material-symbols-outlined">event</span>
            </div>
            <h2 class="text-lg font-bold leading-tight tracking-[-0.015em]">FEvents</h2>
        </div>
        <div class="flex flex-1 justify-end gap-8">
            <nav class="hidden md:flex items-center gap-9">
                <a class="text-[#181411] dark:text-gray-200 text-sm font-medium hover:text-primary transition-colors" asp-page="/Management/CreateEvent" asp-route-tab="events">My Events</a>
                <a class="text-primary text-sm font-bold leading-normal" asp-page="/Management/CreateEvent" asp-route-tab="create">Create Event</a>
            </nav>
            <div class="flex items-center gap-4">
                <div class="relative flex items-center gap-3 cursor-pointer group">
                    <div class="hidden sm:block text-right">
                        <p class="text-sm font-semibold text-[#181411] dark:text-white leading-tight">@Model.FullName</p>
                        <p class="text-xs text-[#8c715f]">Organizer</p>
                    </div>
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border-2 border-white dark:border-[#3e342f] shadow-sm"
                         style='background-image: url("@avatarUrl");'></div>
                    <div class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-[#1a120b] rounded-lg shadow-lg py-1 border border-[#e6dfdb] dark:border-[#3e342f] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                        <a asp-page="/Profile/ViewProfile" class="block px-4 py-2 text-sm text-[#181411] dark:text-white hover:bg-[#f4f2f0] dark:hover:bg-[#3e342f] font-medium">View Profile</a>
                        <hr class="border-[#e6dfdb] dark:border-[#3e342f] my-1" />
                        <a asp-page="/Authentications/Logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-[#f4f2f0] dark:hover:bg-[#3e342f] font-medium">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-1 px-4 md:px-10 lg:px-40 py-8 pb-20">
        <div class="mx-auto max-w-[1024px]">

            @* ── Error state ───────────────────────────────────────────────── *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage) || ev is null)
            {
                <div class="rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 px-6 py-5 text-red-700 dark:text-red-400 mb-6">
                    <p class="font-semibold">@(Model.ErrorMessage ?? "Event not found.")</p>
                </div>
                <a asp-page="/Management/CreateEvent" asp-route-tab="events"
                   class="flex items-center gap-2 text-sm font-medium text-[#8c715f] hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back to My Events
                </a>
            }
            else
            {
                @* ── Breadcrumb + Back ─────────────────────────────────────── *@
                <div class="flex items-center gap-2 mb-6 text-sm text-[#8c715f]">
                    <a asp-page="/Management/CreateEvent" asp-route-tab="events"
                       class="flex items-center gap-1 hover:text-primary transition-colors font-medium">
                        <span class="material-symbols-outlined text-[18px]">arrow_back</span> My Events
                    </a>
                    <span>/</span>
                    <span class="text-[#181411] dark:text-white font-medium line-clamp-1">@ev.Title</span>
                </div>

                @* ── Banner ────────────────────────────────────────────────── *@
                @if (!string.IsNullOrEmpty(ev.ThumbnailUrl))
                {
                    <div class="w-full h-56 md:h-72 rounded-2xl overflow-hidden mb-6 border border-[#e6dfdb] dark:border-[#3e342f]">
                        <img src="@ev.ThumbnailUrl" alt="@ev.Title" class="w-full h-full object-cover">
                    </div>
                }

                @* ── Title row ─────────────────────────────────────────────── *@
                <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-6">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="@statusBg @statusText text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">@statusLabel</span>
                            @if (status == EventStatus.Rejected)
                            {
                                <span class="text-xs text-red-600 dark:text-red-400 font-medium flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">info</span>
                                    Contact admin for rejection reason
                                </span>
                            }
                        </div>
                        <h1 class="text-2xl md:text-3xl font-black text-[#181411] dark:text-white tracking-tight leading-tight">@ev.Title</h1>
                        <p class="text-sm text-[#8c715f] mt-1">Created @ev.CreatedAt.LocalDateTime.ToString("dd MMM yyyy", CultureInfo.InvariantCulture)</p>
                    </div>

                    @* ── Action buttons ──────────────────────────────────────── *@
                    <div class="flex flex-wrap items-center gap-2 flex-shrink-0">
                        @if (canViewParticipants)
                        {
                            <a asp-page="/Management/ViewParticipantList" asp-route-eventId="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[#e6dfdb] dark:border-[#3e342f] bg-white dark:bg-[#2a221b] text-sm font-medium text-[#181411] dark:text-white hover:border-primary hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[16px]">group</span> Participants
                            </a>
                            <a asp-page="/Management/ViewParticipantList" asp-page-handler="Export" asp-route-eventId="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-blue-200 text-sm font-medium text-blue-700 hover:bg-blue-50 transition-colors">
                                <span class="material-symbols-outlined text-[16px]">download</span> Export Registered (Excel)
                            </a>
                            <a asp-page="/Management/ViewParticipantList" asp-page-handler="ExportAttended" asp-route-eventId="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-green-200 text-sm font-medium text-green-700 hover:bg-green-50 transition-colors">
                                <span class="material-symbols-outlined text-[16px]">how_to_reg</span> Export Attended (Excel)
                            </a>
                        }
                        @if (canEdit)
                        {
                            <a asp-page="/Management/UpdateEvent" asp-route-id="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[#e6dfdb] dark:border-[#3e342f] bg-white dark:bg-[#2a221b] text-sm font-medium text-[#181411] dark:text-white hover:border-primary hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[16px]">edit</span> Edit
                            </a>
                        }
                        @if (canPublish)
                        {
                            <a asp-page="/Management/PublishEvent" asp-route-id="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg bg-green-600 text-sm font-medium text-white hover:bg-green-700 transition-colors">
                                <span class="material-symbols-outlined text-[16px]">publish</span> Publish
                            </a>
                        }
                        @if (canCancel)
                        {
                            <a asp-page="/Management/CancelEvent" asp-route-id="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-orange-300 dark:border-orange-700 text-sm font-medium text-orange-600 dark:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-900/20 transition-colors">
                                <span class="material-symbols-outlined text-[16px]">cancel</span> Cancel Event
                            </a>
                        }
                        @if (canDelete)
                        {
                            <a asp-page="/Management/DeleteEvent" asp-route-id="@ev.Id"
                               class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-red-300 dark:border-red-700 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                                <span class="material-symbols-outlined text-[16px]">delete</span> Delete
                            </a>
                        }
                    </div>
                </div>

                @* ── Main grid ─────────────────────────────────────────────── *@
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                    @* Left: Description ──────────────────────────────────────── *@
                    <div class="lg:col-span-2 flex flex-col gap-6">

                        @* Description *@
                        <div class="bg-white dark:bg-[#1a120b] rounded-xl border border-[#e6dfdb] dark:border-[#3e342f] p-6 shadow-sm">
                            <h3 class="text-base font-bold text-[#181411] dark:text-white mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary text-[20px]">description</span>
                                Description
                            </h3>
                            @if (string.IsNullOrWhiteSpace(ev.Description))
                            {
                                <p class="text-sm text-[#8c715f] italic">No description provided.</p>
                            }
                            else
                            {
                                <p class="text-sm text-[#181411] dark:text-[#d0c6c0] leading-relaxed whitespace-pre-line">@ev.Description</p>
                            }
                        </div>

                        @* Registration stats *@
                        <div class="bg-white dark:bg-[#1a120b] rounded-xl border border-[#e6dfdb] dark:border-[#3e342f] p-6 shadow-sm">
                            <h3 class="text-base font-bold text-[#181411] dark:text-white mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary text-[20px]">groups</span>
                                Registrations
                            </h3>
                            <div class="flex items-end justify-between mb-3">
                                <div>
                                    <p class="text-3xl font-black text-[#181411] dark:text-white">@ev.RegisteredCount</p>
                                    <p class="text-sm text-[#8c715f]">of @ev.MaxParticipants capacity</p>
                                </div>
                                <p class="text-2xl font-bold text-primary">@registeredPct%</p>
                            </div>
                            <div class="w-full bg-[#f4f2f0] dark:bg-[#3e342f] rounded-full h-3 overflow-hidden">
                                <div class="bg-primary h-3 rounded-full transition-all duration-500"
                                     style="width: @registeredPct%"></div>
                            </div>
                            @if (canViewParticipants)
                            {
                                <a asp-page="/Management/ViewParticipantList" asp-route-eventId="@ev.Id"
                                   class="mt-4 flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
                                    <span class="material-symbols-outlined text-[16px]">open_in_new</span>
                                    View full participant list
                                </a>
                            }
                        </div>

                    </div>

                    @* Right: Info cards ───────────────────────────────────────── *@
                    <div class="flex flex-col gap-4">

                        @* Date & Time *@
                        <div class="bg-white dark:bg-[#1a120b] rounded-xl border border-[#e6dfdb] dark:border-[#3e342f] p-5 shadow-sm">
                            <h4 class="text-xs font-bold text-[#8c715f] uppercase tracking-wider mb-3">Date & Time</h4>
                            <div class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-primary mt-0.5 text-[20px]">calendar_month</span>
                                <div>
                                    <p class="text-sm font-semibold text-[#181411] dark:text-white">
                                        @ev.StartTime.LocalDateTime.ToString("dddd, dd MMM yyyy", CultureInfo.InvariantCulture)
                                    </p>
                                    <p class="text-xs text-[#8c715f] mt-1">
                                        @ev.StartTime.LocalDateTime.ToString("HH:mm", CultureInfo.InvariantCulture)
                                        —
                                        @ev.EndTime.LocalDateTime.ToString("HH:mm, dd MMM yyyy", CultureInfo.InvariantCulture)
                                    </p>
                                </div>
                            </div>
                        </div>

                        @* Location *@
                        <div class="bg-white dark:bg-[#1a120b] rounded-xl border border-[#e6dfdb] dark:border-[#3e342f] p-5 shadow-sm">
                            <h4 class="text-xs font-bold text-[#8c715f] uppercase tracking-wider mb-3">Location</h4>
                            <div class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-primary mt-0.5 text-[20px]">location_on</span>
                                <div>
                                    <p class="text-sm font-semibold text-[#181411] dark:text-white">@ev.LocationName</p>
                                    @if (!string.IsNullOrEmpty(ev.LocationAddress))
                                    {
                                        <p class="text-xs text-[#8c715f] mt-1">@ev.LocationAddress</p>
                                    }
                                </div>
                            </div>
                        </div>

                        @* Category *@
                        <div class="bg-white dark:bg-[#1a120b] rounded-xl border border-[#e6dfdb] dark:border-[#3e342f] p-5 shadow-sm">
                            <h4 class="text-xs font-bold text-[#8c715f] uppercase tracking-wider mb-3">Category</h4>
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-primary text-[20px]">category</span>
                                <span class="text-sm font-semibold text-[#181411] dark:text-white">@ev.CategoryName</span>
                            </div>
                        </div>

                        @* Organizer *@
                        <div class="bg-white dark:bg-[#1a120b] rounded-xl border border-[#e6dfdb] dark:border-[#3e342f] p-5 shadow-sm">
                            <h4 class="text-xs font-bold text-[#8c715f] uppercase tracking-wider mb-3">Organizer</h4>
                            <div class="flex items-center gap-3">
                                @{
                                    var orgAvatar = ev.OrganizerAvatarUrl
                                        ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(ev.OrganizerName)}&background=f96706&color=fff";
                                }
                                <div class="size-9 rounded-full bg-cover bg-center flex-shrink-0 border border-[#e6dfdb] dark:border-[#3e342f]"
                                     style='background-image: url("@orgAvatar");'></div>
                                <div>
                                    <p class="text-sm font-semibold text-[#181411] dark:text-white">@ev.OrganizerName</p>
                                    <p class="text-xs text-[#8c715f]">Event Organizer</p>
                                </div>
                            </div>
                        </div>

                        @* Quick stats *@
                        <div class="bg-primary/5 dark:bg-primary/10 rounded-xl border border-primary/20 p-5">
                            <h4 class="text-xs font-bold text-[#8c715f] uppercase tracking-wider mb-3">Quick Stats</h4>
                            <div class="grid grid-cols-2 gap-3">
                                <div class="text-center">
                                    <p class="text-xl font-black text-primary">@ev.MaxParticipants</p>
                                    <p class="text-xs text-[#8c715f]">Max Capacity</p>
                                </div>
                                <div class="text-center">
                                    <p class="text-xl font-black text-primary">@ev.RegisteredCount</p>
                                    <p class="text-xs text-[#8c715f]">Registered</p>
                                </div>
                                <div class="text-center col-span-2">
                                    <p class="text-xl font-black text-[#181411] dark:text-white">@(ev.MaxParticipants - ev.RegisteredCount)</p>
                                    <p class="text-xs text-[#8c715f]">Spots Remaining</p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }

        </div>
    </main>

</body>
</html>
