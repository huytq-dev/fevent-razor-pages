@page "{eventId:guid?}"
@model UI.ViewParticipantListModel
@{
    ViewData["Title"] = "Participant List";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - FEvents</title>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f96706",
                        "background-light": "#f8f7f5",
                        "background-dark": "#23170f",
                        "surface-light": "#ffffff",
                        "surface-dark": "#2c1e14",
                        "text-main": "#181411",
                        "text-secondary": "#8c715f",
                    },
                    fontFamily: {
                        "display": ["Lexend", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        /* Custom scrollbar for better look in table */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-text-main dark:text-white overflow-x-hidden transition-colors duration-200">
    <div class="relative flex h-full min-h-screen w-full flex-col">
        <!-- Navigation Header -->
        <header class="sticky top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-[#f5f2f0] dark:border-[#3e2c22] bg-surface-light dark:bg-surface-dark px-6 py-3 shadow-sm lg:px-10">
            <div class="flex items-center gap-4 text-text-main dark:text-white">
                <div class="size-8 text-primary">
                    <svg class="w-full h-full" fill="none" viewbox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                        <path clip-rule="evenodd" d="M24 18.4228L42 11.475V34.3663C42 34.7796 41.7457 35.1504 41.3601 35.2992L24 42V18.4228Z" fill="currentColor" fill-rule="evenodd"></path>
                        <path clip-rule="evenodd" d="M24 8.18819L33.4123 11.574L24 15.2071L14.5877 11.574L24 8.18819ZM9 15.8487L21 20.4805V37.6263L9 32.9945V15.8487ZM27 37.6263V20.4805L39 15.8487V32.9945L27 37.6263ZM25.354 2.29885C24.4788 1.98402 23.5212 1.98402 22.646 2.29885L4.98454 8.65208C3.7939 9.08038 3 10.2097 3 11.475V34.3663C3 36.0196 4.01719 37.5026 5.55962 38.098L22.9197 44.7987C23.6149 45.0671 24.3851 45.0671 25.0803 44.7987L42.4404 38.098C43.9828 37.5026 45 36.0196 45 34.3663V11.475C45 10.2097 44.2061 9.08038 43.0155 8.65208L25.354 2.29885Z" fill="currentColor" fill-rule="evenodd"></path>
                    </svg>
                </div>
                <h2 class="text-text-main dark:text-white text-xl font-bold leading-tight tracking-[-0.015em]">FEvents</h2>
            </div>
            <div class="hidden md:flex flex-1 justify-center gap-8 px-8">
                <nav class="flex items-center gap-9">
                    <a class="text-text-main dark:text-gray-200 text-sm font-medium hover:text-primary transition-colors" asp-page="/Management/CreateEvent" asp-route-tab="events">Dashboard</a>
                    <a class="text-primary text-sm font-bold border-b-2 border-primary pb-0.5" asp-page="/Management/CreateEvent" asp-route-tab="events">My Events</a>
                    <a class="text-text-main dark:text-gray-200 text-sm font-medium hover:text-primary transition-colors" href="#">Students</a>
                    <a class="text-text-main dark:text-gray-200 text-sm font-medium hover:text-primary transition-colors" href="#">Settings</a>
                </nav>
            </div>
            <div class="flex items-center justify-end gap-4 lg:gap-8">
                <button class="flex items-center justify-center overflow-hidden rounded-full size-10 bg-[#f5f2f0] dark:bg-[#3e2c22] text-text-main dark:text-white hover:bg-gray-200 dark:hover:bg-[#523a2d] transition-colors">
                    <span class="material-symbols-outlined text-[24px]">notifications</span>
                </button>
                <div class="bg-center bg-no-repeat bg-cover rounded-full size-10 border-2 border-white dark:border-[#3e2c22] shadow-sm cursor-pointer" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBIjK2CCXpQOL0rcThYD3_gdCr3eiUysHTbQQHeE7pP-o_Qz71-HNuHM_FCZrzsLOTPwgako-vGZjUuEo__esGB4FOp7su6X7uHdS-5rOxZJJAlQ0zuk_mFFa906BPbLq4EBZoVnHnUpmXwY_2oFdzayXaMUWaQzb3reatK9-eszbrtcWK-zTZutHDssJohFJ5zHb7sfCfNXiCQycRHL2HyGHUcsh9seP6emeaY4X4hFX7bYi96xdt24gwuAliA2BGfgtwqI8dcT3lz");'></div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="flex-1 px-4 sm:px-6 lg:px-20 xl:px-40 py-8 w-full max-w-[1440px] mx-auto">
            <!-- Breadcrumbs -->
            <div class="flex flex-wrap items-center gap-2 mb-6">
                <a class="text-text-secondary dark:text-gray-400 text-sm font-medium hover:text-primary transition-colors" asp-page="/Management/CreateEvent" asp-route-tab="events">Home</a>
                <span class="material-symbols-outlined text-text-secondary dark:text-gray-400 text-sm">chevron_right</span>
                <a class="text-text-secondary dark:text-gray-400 text-sm font-medium hover:text-primary transition-colors" asp-page="/Management/CreateEvent" asp-route-tab="events">My Events</a>
                <span class="material-symbols-outlined text-text-secondary dark:text-gray-400 text-sm">chevron_right</span>
                <a class="text-text-secondary dark:text-gray-400 text-sm font-medium hover:text-primary transition-colors" asp-page="/Management/EventDetail" asp-route-id="@Model.ViewModel.EventId">@Model.ViewModel.EventTitle</a>
                <span class="material-symbols-outlined text-text-secondary dark:text-gray-400 text-sm">chevron_right</span>
                <span class="text-text-main dark:text-white text-sm font-medium">Participants</span>
            </div>

            <!-- Page Header -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-8">
                <div class="flex flex-col gap-2">
                    <h1 class="text-text-main dark:text-white text-3xl md:text-4xl font-black leading-tight tracking-[-0.033em]">
                        @Model.ViewModel.EventTitle - Participant List
                    </h1>
                    <p class="text-text-secondary dark:text-gray-400 text-base font-normal">
                        Manage student registrations, attendance, and certificates.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="flex flex-col items-end">
                        <span class="text-xs text-text-secondary dark:text-gray-400 font-medium uppercase tracking-wider">Total Registered</span>
                        <span class="text-2xl font-bold text-text-main dark:text-white">@Model.ViewModel.TotalRegistered</span>
                    </div>
                </div>
            </div>

            <!-- Controls Toolbar (Search, Filter, Export) -->
            <form method="get" asp-page="/Management/ViewParticipantList" asp-route-eventId="@Model.ViewModel.EventId" class="flex flex-col xl:flex-row gap-4 mb-6 bg-surface-light dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-[#f5f2f0] dark:border-[#3e2c22]">
                <!-- Search -->
                <div class="w-full xl:w-1/3">
                    <label class="flex w-full items-center rounded-full bg-[#f5f2f0] dark:bg-[#3e2c22] h-12 px-4 border transition-colors border-transparent focus-within:border-primary">
                        <span class="material-symbols-outlined text-text-secondary dark:text-gray-400 mr-2">search</span>
                        <input asp-for="Search" class="flex w-full bg-transparent border-none text-text-main dark:text-white placeholder:text-text-secondary dark:placeholder:text-gray-500 focus:ring-0 text-base" placeholder="Search by name, MSSV, email, ticket" />
                    </label>
                </div>
                <!-- Filters -->
                <div class="flex flex-1 flex-wrap gap-3 items-center">
                    <select asp-for="MajorFilter" class="group flex h-10 items-center gap-2 rounded-full border border-[#e6e0db] dark:border-[#523a2d] hover:border-primary dark:hover:border-primary bg-transparent px-4 transition-all text-sm font-medium text-text-main focus:ring-primary">
                        <option value="">All Majors</option>
                        @foreach (var m in Model.ViewModel.MajorFilterOptions)
                        {
                            <option value="@m">@m</option>
                        }
                    </select>
                    <select asp-for="StatusFilter" class="group flex h-10 items-center gap-2 rounded-full border border-[#e6e0db] dark:border-[#523a2d] hover:border-primary dark:hover:border-primary bg-transparent px-4 transition-all text-sm font-medium text-text-main focus:ring-primary">
                        <option value="">All Status</option>
                        <option value="Registered">Registered</option>
                        <option value="Checked-in">Checked-in</option>
                        <option value="Pending Payment">Pending Payment</option>
                        <option value="Paid">Paid</option>
                    </select>
                </div>
                <!-- Actions -->
                <div class="flex gap-3 mt-2 xl:mt-0 w-full xl:w-auto">
                    <button type="submit" class="flex-1 xl:flex-none h-12 items-center justify-center gap-2 rounded-full border border-primary text-primary px-6 font-bold text-sm hover:bg-primary hover:text-white transition-all">
                        Apply Filters
                    </button>
                    <a asp-page="/Management/ViewParticipantList" asp-page-handler="Export" asp-route-eventId="@Model.ViewModel.EventId" class="flex-1 xl:flex-none h-12 inline-flex items-center justify-center gap-2 rounded-full bg-primary hover:bg-orange-600 text-white px-6 font-bold text-sm transition-colors shadow-lg shadow-orange-500/20">
                        <span class="material-symbols-outlined text-[20px]">download</span>
                        Export Registered (Excel)
                    </a>
                    <a asp-page="/Management/ViewParticipantList" asp-page-handler="ExportAttended" asp-route-eventId="@Model.ViewModel.EventId" class="flex-1 xl:flex-none h-12 inline-flex items-center justify-center gap-2 rounded-full border border-green-600 text-green-700 hover:bg-green-50 px-6 font-bold text-sm transition-colors">
                        <span class="material-symbols-outlined text-[20px]">how_to_reg</span>
                        Export Attended (Excel)
                    </a>
                </div>
            </form>

            <!-- Data Table Card -->
            <div class="w-full overflow-hidden rounded-xl border border-[#e6e0db] dark:border-[#3e2c22] bg-surface-light dark:bg-surface-dark shadow-sm">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[#f5f2f0]/50 dark:bg-[#2c1e14] border-b border-[#e6e0db] dark:border-[#3e2c22]">
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400 w-16 text-center">#</th>
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400 min-w-[200px]">Full Name</th>
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400">MSSV</th>
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400">Major</th>
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400">Registration Date</th>
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400">Status</th>
                                <th class="p-4 text-xs font-bold uppercase tracking-wider text-text-secondary dark:text-gray-400 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#e6e0db] dark:divide-[#3e2c22]">
                            @if (Model.ViewModel.Participants != null && Model.ViewModel.Participants.Any())
                            {
                                @foreach (var item in Model.ViewModel.Participants)
                                {
                                    <tr class="group hover:bg-background-light dark:hover:bg-[#36261b] transition-colors">
                                        <td class="p-4 text-sm text-text-secondary dark:text-gray-500 text-center">@item.Order.ToString("D2")</td>
                                        <td class="p-4">
                                            <div class="flex items-center gap-3">
                                                @{
                                                    var avatar = string.IsNullOrWhiteSpace(item.AvatarUrl)
                                                        ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(item.FullName)}&background=f96706&color=fff"
                                                        : item.AvatarUrl;
                                                }
                                                <img src="@avatar" alt="@item.FullName" class="size-8 rounded-full object-cover border border-[#e6e0db] dark:border-[#523a2d]" />
                                                <div>
                                                    <p class="text-sm font-bold text-text-main dark:text-white">@item.FullName</p>
                                                    @if (!string.IsNullOrWhiteSpace(item.Email) && item.Email != "—")
                                                    {
                                                        <p class="text-xs text-text-secondary dark:text-gray-500">@item.Email</p>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="p-4 text-sm font-medium text-text-main dark:text-gray-300 font-mono">@item.Mssv</td>
                                        <td class="p-4 text-sm text-text-main dark:text-gray-300">@item.Major</td>
                                        <td class="p-4 text-sm text-text-secondary dark:text-gray-400">@item.RegistrationDate.ToString("MMM dd, yyyy - hh:mm tt")</td>
                                        <td class="p-4">
                                            @if (item.Status == "Registered")
                                            {
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-xs font-bold border border-blue-100 dark:border-blue-800">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                                                    @item.Status
                                                </span>
                                            }
                                            else if (item.Status == "Checked-in")
                                            {
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 text-xs font-bold border border-green-100 dark:border-green-800">
                                                    <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                                    @item.Status
                                                </span>
                                            }
                                            else if (item.Status == "Pending Payment")
                                            {
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 text-xs font-bold border border-amber-100 dark:border-amber-800">
                                                    <span class="material-symbols-outlined text-[14px]">schedule</span>
                                                    @item.Status
                                                </span>
                                            }
                                            else if (item.Status == "Paid")
                                            {
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold border border-emerald-100 dark:border-emerald-800">
                                                    <span class="material-symbols-outlined text-[14px]">payments</span>
                                                    @item.Status
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800/40 text-gray-700 dark:text-gray-300 text-xs font-bold border border-gray-200 dark:border-gray-600">
                                                    @item.Status
                                                </span>
                                            }
                                        </td>
                                        <td class="p-4 text-right">
                                            <button class="text-text-secondary hover:text-primary transition-colors p-2 rounded-full hover:bg-orange-50 dark:hover:bg-orange-900/20">
                                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="p-20 text-center">
                                        <div class="flex flex-col items-center gap-3">
                                            <span class="material-symbols-outlined text-gray-300 text-6xl">person_off</span>
                                            <p class="text-text-secondary dark:text-gray-400 font-medium">No participants found for this event.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Summary row -->
                <div class="flex flex-wrap items-center justify-between border-t border-[#e6e0db] dark:border-[#3e2c22] p-4 bg-[#f5f2f0]/30 dark:bg-[#2c1e14]/50 gap-4">
                    <p class="text-sm text-text-secondary dark:text-gray-400">
                        Showing <span class="font-bold text-text-main dark:text-white">@(Model.ViewModel.Participants?.Count ?? 0)</span> of <span class="font-bold text-text-main dark:text-white">@Model.ViewModel.TotalRegistered</span> registrations
                    </p>
                </div>
            </div>
        </main>

        <!-- Simple Footer -->
        <footer class="mt-auto py-6 text-center text-sm text-text-secondary dark:text-gray-500">
            <p>© 2024 FPT University. All rights reserved.</p>
        </footer>
    </div>
</body>
</html>
