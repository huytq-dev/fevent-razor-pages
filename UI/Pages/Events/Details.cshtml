@page "/events/{id:guid}"
@using Contract
@using Domain
@using System.Globalization
@model UI.DetailsModel
@{
    ViewData["Title"] = Model.Event?.Title ?? "Chi tiết sự kiện";
    var ev = Model.Event;
}

<div class="bg-background min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) || ev is null)
        {
            <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-6 text-red-700 mb-6">
                @(Model.ErrorMessage ?? "Không tìm thấy sự kiện.")
            </div>
            <a href="/Home/find-events" class="inline-block mt-4 text-primary hover:underline font-medium">← Quay lại danh sách sự kiện</a>
        }
        else
        {
        <nav class="flex text-sm text-muted-foreground mb-6 font-medium">
            <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
            <span class="mx-2">/</span>
            <a href="/Home/find-events" class="hover:text-primary transition-colors">Sự kiện</a>
            <span class="mx-2">/</span>
            <span class="text-foreground line-clamp-1">@ev.Title</span>
        </nav>

        <div class="relative w-full h-[300px] md:h-[400px] rounded-3xl overflow-hidden mb-8 shadow-sm">
            @if (!string.IsNullOrWhiteSpace(ev.ThumbnailUrl))
            {
                <img src="@ev.ThumbnailUrl" alt="@ev.Title" class="w-full h-full object-cover">
            }
            else
            {
                <div class="w-full h-full bg-gradient-to-br from-primary/80 to-primary flex items-center justify-center text-white text-4xl font-bold">
                    @(ev.CategoryName?.Substring(0, 1).ToUpperInvariant() ?? "E")
                </div>
            }
            <div class="absolute top-5 left-5 flex flex-wrap gap-2">
                <span class="bg-white/95 text-foreground font-bold text-[10px] sm:text-xs px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
                    @(ev.CategoryName ?? "Sự kiện")
                </span>
                @{
                    var status = (EventStatus)ev.Status;
                    var statusLabel = status switch
                    {
                        EventStatus.Approved => "Mở đăng ký",
                        EventStatus.Pending => "Đang chờ",
                        EventStatus.Draft => "Bản nháp",
                        EventStatus.Rejected => "Từ chối",
                        EventStatus.Cancelled => "Đã hủy",
                        EventStatus.Completed => "Đã kết thúc",
                        _ => "Không xác định"
                    };
                    var isOpen = status == EventStatus.Approved;
                }
                <span class="bg-primary text-white font-bold text-[10px] sm:text-xs px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm flex items-center gap-1.5">
                    @if (isOpen) { <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span> }
                    @statusLabel
                </span>
            </div>
        </div>

        <div class="mb-10">
            <h1 class="text-3xl md:text-5xl font-display font-extrabold text-foreground mb-4 leading-tight">
                @ev.Title
            </h1>
            <div class="flex flex-wrap items-center text-muted-foreground gap-4 md:gap-6 text-sm font-medium">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    @ev.StartTime.ToString("dd 'Thg' MM, yyyy", new CultureInfo("vi-VN"))
                </span>
                <span class="hidden md:block w-1.5 h-1.5 rounded-full bg-border"></span>
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    @ev.StartTime.ToString("HH:mm") - @ev.EndTime.ToString("HH:mm")
                </span>
                <span class="hidden md:block w-1.5 h-1.5 rounded-full bg-border"></span>
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    @(ev.LocationName ?? "Chưa cập nhật")
                </span>
            </div>
        </div>

        <div class="border-t border-border w-full mb-10"></div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

            <div class="lg:col-span-2 space-y-12">

                <section>
                    <h2 class="text-2xl font-display font-bold text-foreground mb-4">Về sự kiện này</h2>
                    <div class="prose prose-sm sm:prose-base text-secondary-foreground space-y-4 max-w-none">
                        @if (!string.IsNullOrWhiteSpace(ev.Description))
                        {
                            <p class="whitespace-pre-wrap">@ev.Description</p>
                        }
                        else
                        {
                            <p class="text-muted-foreground">Chưa có mô tả chi tiết.</p>
                        }
                    </div>
                </section>

                <section>
                    <h2 class="text-2xl font-display font-bold text-foreground mb-6">Người tổ chức</h2>
                    <div class="flex items-center gap-4 p-4 bg-card border border-border rounded-2xl">
                        <img src="@(ev.OrganizerAvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(ev.OrganizerName)}&background=f96706&color=fff&size=128")" alt="@ev.OrganizerName" class="w-16 h-16 rounded-full object-cover border-2 border-border">
                        <div>
                            <h3 class="font-bold text-foreground text-lg">@ev.OrganizerName</h3>
                            <p class="text-sm text-muted-foreground">Người tổ chức sự kiện</p>
                        </div>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-1">
                <div class="sticky top-24 space-y-6">

                    <div class="bg-card border border-border rounded-3xl p-6 shadow-sm">
                        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                        {
                            <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-700 text-sm">
                                @Model.SuccessMessage
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.RegisterMessage))
                        {
                            <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700 text-sm">
                                @Model.RegisterMessage
                            </div>
                        }
                        <div class="flex justify-between items-end mb-6">
                            <span class="text-muted-foreground text-sm font-medium">Giá vé</span>
                            <span class="text-2xl font-bold text-foreground">Miễn phí</span>
                        </div>
                        @if (Model.IsRegistered)
                        {
                            <div class="w-full bg-green-50 text-success font-medium py-3.5 rounded-xl mb-3 text-center flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Đã đăng ký
                            </div>
                            <form method="post" asp-page-handler="Cancel" class="mb-3" onsubmit="return confirm('Bạn có chắc muốn hủy đăng ký sự kiện này?');">
                                <button type="submit" class="w-full border border-destructive text-destructive hover:bg-destructive/10 font-medium py-3 rounded-xl transition-colors">
                                    Hủy đăng ký
                                </button>
                            </form>
                        }
                        else if (isOpen)
                        {
                            <form method="post" asp-page-handler="Register">
                                <button type="submit" class="w-full bg-primary hover:bg-primary-hover text-white font-bold py-3.5 rounded-xl transition-all shadow-primary transform hover:-translate-y-0.5 mb-3">
                                    Đăng ký ngay
                                </button>
                            </form>
                        }
                        else
                        {
                            <button disabled class="w-full bg-secondary text-secondary-foreground font-medium py-3.5 rounded-xl cursor-not-allowed mb-3">
                                Đã đóng đăng ký
                            </button>
                        }
                        <p class="text-center text-xs text-muted-foreground">@ev.RegisteredCount / @ev.MaxParticipants đã đăng ký</p>
                    </div>

                    <div class="bg-card border border-border rounded-3xl p-6 shadow-sm">
                        <h3 class="font-bold text-foreground text-lg mb-5">Chi tiết sự kiện</h3>

                        <div class="space-y-5 mb-6">
                            <div class="flex gap-4">
                                <div class="bg-orange-50 text-primary p-2.5 rounded-xl h-fit">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                </div>
                                <div>
                                    <p class="font-bold text-foreground text-sm">@ev.StartTime.ToString("dddd, dd 'Thg' MM", new CultureInfo("vi-VN"))</p>
                                    <p class="text-muted-foreground text-xs mb-1">@ev.StartTime.ToString("HH:mm") - @ev.EndTime.ToString("HH:mm")</p>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <div class="bg-orange-50 text-primary p-2.5 rounded-xl h-fit">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                </div>
                                <div>
                                    <p class="font-bold text-foreground text-sm">@ev.LocationName</p>
                                    @if (!string.IsNullOrWhiteSpace(ev.LocationAddress))
                                    {
                                        <p class="text-muted-foreground text-xs">@ev.LocationAddress</p>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(ev.LocationMapUrl))
                        {
                            <a href="@ev.LocationMapUrl" target="_blank" rel="noopener noreferrer" class="block relative w-full h-32 bg-[#e0ecdf] rounded-xl overflow-hidden group cursor-pointer border border-border">
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <svg class="w-8 h-8 text-primary drop-shadow-md" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                                </div>
                                <div class="absolute bottom-2 right-2 bg-white/90 px-3 py-1 rounded-full text-xs font-bold text-foreground shadow-sm group-hover:bg-white transition-colors">
                                    Xem bản đồ
                                </div>
                            </a>
                        }
                    </div>

                    <div class="bg-card border border-border rounded-3xl p-5 shadow-sm flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <img src="@(ev.OrganizerAvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(ev.OrganizerName)}&background=f96706&color=fff")" alt="@ev.OrganizerName" class="w-10 h-10 rounded-full border border-border object-cover">
                            <div>
                                <p class="text-[10px] text-muted-foreground uppercase tracking-wider font-bold mb-0.5">Tổ chức bởi</p>
                                <p class="font-bold text-foreground text-sm">@ev.OrganizerName</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
        }
    </div>
</div>