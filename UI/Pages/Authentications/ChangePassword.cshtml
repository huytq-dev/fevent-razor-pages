@page "/change-password"
@model UI.ChangePasswordModel
@{
    ViewData["Title"] = "FEvents - Đổi Mật Khẩu";
    Layout = "~/Pages/Shared/Authentications/_AuthLayout.cshtml";
}

<div class="flex w-full min-h-screen bg-white">

    @* Left decorative panel *@
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-gray-900 items-end justify-start group">
        <img alt="Khuôn viên Đại học FPT"
             class="absolute inset-0 w-full h-full object-cover object-center opacity-80 transition-transform duration-1000 group-hover:scale-105"
             src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqNNUcMI7LMQ1X2T-nZNvE7gyO_yfhDxg1V6HKyA078xR1CLu-7bYi6Ljt67J5bPqonYfuHu59rwNY3vLuNgHcE2nB7jITXrWeXtnAcxmJEJpCKcroMAosTrea_3Tvy3J5jXCGnbMi5vr5KqRjN0KtnhmcPqxYTpCqXi_JLGTcM6kMaFKSy1_NSJQgDUoOoSmYHSFiTZnI4LGWBYGsOwzoIb1wBeKP71QCAGj0yZucoC_YuJv3RCU2y1WCw20-DGjAEQbpEjdSB3_v" />
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/90 via-primary/40 to-transparent mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        @* Logo top-left *@
        <div class="absolute top-10 left-10 flex items-center gap-3 z-20">
            <div class="flex items-center justify-center size-10 rounded-lg bg-white/10 backdrop-blur-md text-white border border-white/20">
                <svg class="size-6" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path clip-rule="evenodd" d="M24 18.4228L42 11.475V34.3663C42 34.7796 41.7457 35.1504 41.3601 35.2992L24 42V18.4228Z" fill="#ffffff" fill-rule="evenodd"></path>
                    <path clip-rule="evenodd" d="M24 8.18819L33.4123 11.574L24 15.2071L14.5877 11.574L24 8.18819ZM9 15.8487L21 20.4805V37.6263L9 32.9945V15.8487ZM27 37.6263V20.4805L39 15.8487V32.9945L27 37.6263ZM25.354 2.29885C24.4788 1.98402 23.5212 1.98402 22.646 2.29885L4.98454 8.65208C3.7939 9.08038 3 10.2097 3 11.475V34.3663C3 36.0196 4.01719 37.5026 5.55962 38.098L22.9197 44.7987C23.6149 45.0671 24.3851 45.0671 25.0803 44.7987L42.4404 38.098C43.9828 37.5026 45 36.0196 45 34.3663V11.475C45 10.2097 44.2061 9.08038 43.0155 8.65208L25.354 2.29885Z" fill="currentColor" fill-rule="evenodd"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-white drop-shadow-md">FEvents</h2>
        </div>

        @* Bottom text *@
        <div class="relative z-10 p-12 max-w-2xl">
            <div class="flex items-center gap-3 mb-4">
                <div class="flex items-center justify-center size-12 rounded-xl bg-white/10 backdrop-blur-md border border-white/20">
                    <span class="material-symbols-outlined text-white text-2xl">lock_reset</span>
                </div>
            </div>
            <h1 class="text-5xl font-black text-white mb-4 leading-tight tracking-tight drop-shadow-xl">
                Bảo Mật Tài Khoản.
            </h1>
            <p class="text-lg text-white/90 font-medium max-w-md leading-relaxed drop-shadow-lg">
                Cập nhật mật khẩu định kỳ giúp bảo vệ tài khoản của bạn khỏi các truy cập trái phép.
            </p>
            <div class="mt-8 flex gap-6">
                <div class="flex items-center gap-2 text-white/80 text-sm font-medium">
                    <span class="material-symbols-outlined text-base text-green-400">check_circle</span>
                    Mã hóa an toàn
                </div>
                <div class="flex items-center gap-2 text-white/80 text-sm font-medium">
                    <span class="material-symbols-outlined text-base text-green-400">check_circle</span>
                    Xác thực 2 bước
                </div>
            </div>
        </div>
    </div>

    @* Right form panel *@
    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center p-6 sm:p-12 xl:p-24 bg-white overflow-y-auto custom-scrollbar">
        <div class="w-full max-w-md space-y-8">

            @* Mobile logo *@
            <div class="lg:hidden flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-3xl">event_upcoming</span>
                <span class="text-2xl font-black tracking-tight text-gray-900">FEvents</span>
            </div>

            @* Header *@
            <div class="space-y-2">
                <div class="flex items-center gap-3 mb-2">
                    <div class="flex items-center justify-center size-11 rounded-xl bg-primary/10 text-primary">
                        <span class="material-symbols-outlined text-2xl">lock_reset</span>
                    </div>
                </div>
                <h2 class="text-3xl font-black tracking-tighter text-gray-900">Đổi Mật Khẩu</h2>
                <p class="text-gray-500 font-medium">Nhập mật khẩu hiện tại và mật khẩu mới của bạn.</p>
            </div>

            @* Success message *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm font-medium">
                    <span class="material-symbols-outlined text-green-500 text-xl">check_circle</span>
                    @TempData["SuccessMessage"]
                </div>
            }

            @* Error summary *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm font-medium">
                    <span class="material-symbols-outlined text-red-500 text-xl mt-0.5">error</span>
                    <div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            @* Form *@
            <form method="post" class="space-y-5">

                @* Current password *@
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Mật Khẩu Hiện Tại</label>
                    <div class="relative flex items-center rounded-xl border border-gray-300 bg-gray-50 focus-within:ring-2 focus-within:ring-primary/20 focus-within:border-primary transition-all">
                        <span class="material-symbols-outlined text-gray-400 text-xl ml-4">lock</span>
                        <input asp-for="Input.CurrentPassword" id="currentPasswordInput"
                               class="flex-1 h-12 bg-transparent text-gray-900 placeholder:text-gray-400 focus:outline-none font-medium text-sm px-3"
                               placeholder="Nhập mật khẩu hiện tại" type="password" />
                        <button type="button" onclick="togglePassword('currentPasswordInput', 'currentToggleIcon')"
                                class="px-3 text-gray-400 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl" id="currentToggleIcon">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.CurrentPassword" class="text-xs text-destructive mt-1 block"></span>
                </div>

                <div class="relative flex items-center gap-3 py-1">
                    <div class="h-px flex-1 bg-gray-200"></div>
                    <span class="text-xs text-gray-400 font-medium uppercase tracking-wider">Mật khẩu mới</span>
                    <div class="h-px flex-1 bg-gray-200"></div>
                </div>

                @* New password *@
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Mật Khẩu Mới</label>
                    <div class="relative flex items-center rounded-xl border border-gray-300 bg-gray-50 focus-within:ring-2 focus-within:ring-primary/20 focus-within:border-primary transition-all">
                        <span class="material-symbols-outlined text-gray-400 text-xl ml-4">lock_open</span>
                        <input asp-for="Input.NewPassword" id="newPasswordInput"
                               class="flex-1 h-12 bg-transparent text-gray-900 placeholder:text-gray-400 focus:outline-none font-medium text-sm px-3"
                               placeholder="Tạo mật khẩu mới" type="password" />
                        <button type="button" onclick="togglePassword('newPasswordInput', 'newToggleIcon')"
                                class="px-3 text-gray-400 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl" id="newToggleIcon">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-xs text-destructive mt-1 block"></span>

                    @* Strength bars *@
                    <div class="flex items-center gap-1.5 pt-1 px-1">
                        <div id="sBar1" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <div id="sBar2" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <div id="sBar3" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <div id="sBar4" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <span id="sText" class="text-[10px] font-bold text-gray-400 ml-1 uppercase tracking-wider">YẾU</span>
                    </div>

                    @* Conditions list *@
                    <ul id="condList" class="text-xs mt-2 font-medium space-y-1"></ul>
                </div>

                @* Confirm new password *@
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Xác Nhận Mật Khẩu Mới</label>
                    <div class="relative flex items-center rounded-xl border border-gray-300 bg-gray-50 focus-within:ring-2 focus-within:ring-primary/20 focus-within:border-primary transition-all">
                        <span class="material-symbols-outlined text-gray-400 text-xl ml-4">verified</span>
                        <input asp-for="Input.ConfirmPassword" id="confirmPasswordInput"
                               class="flex-1 h-12 bg-transparent text-gray-900 placeholder:text-gray-400 focus:outline-none font-medium text-sm px-3"
                               placeholder="Nhập lại mật khẩu mới" type="password" />
                        <button type="button" onclick="togglePassword('confirmPasswordInput', 'confirmToggleIcon')"
                                class="px-3 text-gray-400 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl" id="confirmToggleIcon">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-destructive mt-1 block"></span>

                    @* Match indicator *@
                    <div id="matchIndicator" class="hidden flex items-center gap-1.5 px-1 pt-1 text-xs font-medium">
                        <span class="material-symbols-outlined text-sm" id="matchIcon">cancel</span>
                        <span id="matchText">Mật khẩu không khớp</span>
                    </div>
                </div>

                @* Submit *@
                <button type="submit"
                        class="w-full py-4 px-6 bg-primary hover:bg-primary-hover text-white font-bold rounded-xl shadow-primary hover:-translate-y-0.5 transition-all duration-200 active:scale-[0.98] flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-xl">lock_reset</span>
                    Cập Nhật Mật Khẩu
                </button>

            </form>

            @* Back link *@
            <div class="text-center pt-2">
                <a asp-page="/Index" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Quay về trang chủ
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon  = document.getElementById(iconId);
            var isPassword = input.type === "password";
            input.type       = isPassword ? "text" : "password";
            icon.textContent = isPassword ? "visibility_off" : "visibility";
        }

        var condRegexes = [/.{8,}/, /[A-Z]/, /[a-z]/, /\d/, /[^A-Za-z0-9]/];
        var condLabels  = ["It nhat 8 ky tu", "Chu hoa (A-Z)", "Chu thuong (a-z)", "Chu so (0-9)", "Ky tu dac biet"];

        var bars         = [
            document.getElementById("sBar1"),
            document.getElementById("sBar2"),
            document.getElementById("sBar3"),
            document.getElementById("sBar4")
        ];
        var sText        = document.getElementById("sText");
        var condList     = document.getElementById("condList");
        var newInput     = document.getElementById("newPasswordInput");
        var confirmInput = document.getElementById("confirmPasswordInput");

        var colorMap = ["bg-gray-200","bg-red-400","bg-red-400","bg-yellow-400","bg-blue-400","bg-green-500"];
        var labelMap = ["YEU","YEU","YEU","TRUNG BINH","KHA","MANH"];
        var colorTextMap = ["text-gray-400","text-red-400","text-red-400","text-yellow-400","text-blue-400","text-green-500"];

        var condViLabels = [
            "It nhat 8 ky tu",
            "Chu hoa (A-Z)",
            "Chu thuong (a-z)",
            "Chu so (0-9)",
            "Ky tu dac biet"
        ];

        function updateStrength(password) {
            var met = condRegexes.map(function(r) { return r.test(password); });
            var strength = met.filter(Boolean).length;

            bars.forEach(function(bar, i) {
                bar.className = "h-1 flex-1 rounded-full transition-colors duration-300 " +
                    (i < strength ? colorMap[strength] : "bg-gray-200");
            });

            sText.textContent = labelMap[strength];
            sText.className   = "text-[10px] font-bold ml-1 uppercase tracking-wider transition-colors duration-300 " + colorTextMap[strength];

            var html = "";
            for (var i = 0; i < condRegexes.length; i++) {
                var iconColor = met[i] ? "text-green-500" : "text-gray-300";
                var iconName  = met[i] ? "check_circle" : "cancel";
                var textColor = met[i] ? "text-gray-700" : "text-gray-400";
                html += '<li class="flex items-center gap-1.5">' +
                    '<span class="material-symbols-outlined text-sm ' + iconColor + '">' + iconName + '</span>' +
                    '<span class="' + textColor + '">' + condViLabels[i] + '</span>' +
                    '</li>';
            }
            condList.innerHTML = html;
        }

        function checkMatch() {
            var indicator = document.getElementById("matchIndicator");
            var icon      = document.getElementById("matchIcon");
            var text      = document.getElementById("matchText");
            var confVal   = confirmInput.value;

            if (!confVal) { indicator.classList.add("hidden"); return; }

            indicator.classList.remove("hidden");
            var match        = newInput.value === confVal;
            icon.textContent = match ? "check_circle" : "cancel";
            icon.className   = "material-symbols-outlined text-sm " + (match ? "text-green-500" : "text-red-400");
            text.textContent = match ? "Mat khau khop" : "Mat khau khong khop";
            text.className   = match ? "text-green-600" : "text-red-500";
        }

        newInput.addEventListener("input", function() { updateStrength(newInput.value); checkMatch(); });
        confirmInput.addEventListener("input", checkMatch);
        updateStrength("");
    </script>
}
