@page "/forgot-password"
@model UI.ForgotPasswordModel
@{
    ViewData["Title"] = "FEvents - Quên Mật Khẩu";
    Layout = "~/Pages/Shared/Authentications/_AuthLayout.cshtml";
}

<div class="flex w-full min-h-screen bg-white">

    @* Left decorative panel *@
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-gray-900 items-end justify-start group">
        <img alt="Khuôn viên Đại học FPT"
             class="absolute inset-0 w-full h-full object-cover object-center opacity-80 transition-transform duration-1000 group-hover:scale-105"
             src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqNNUcMI7LMQ1X2T-nZNvE7gyO_yfhDxg1V6HKyA078xR1CLu-7bYi6Ljt67J5bPqonYfuHu59rwNY3vLuNgHcE2nB7jITXrWeXtnAcxmJEJpCKcroMAosTrea_3Tvy3J5jXCGnbMi5vr5KqRjN0KtnhmcPqxYTpCqXi_JLGTcM6kMaFKSy1_NSJQgDUoOoSmYHSFiTZnI4LGWBYGsOwzoIb1wBeKP71QCAGj0yZucoC_YuJv3RCU2y1WCw20-DGjAEQbpEjdSB3_v" />
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/90 via-primary/40 to-transparent mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        @* Logo top-left *@
        <div class="absolute top-10 left-10 flex items-center gap-3 z-20">
            <div class="flex items-center justify-center size-10 rounded-lg bg-white/10 backdrop-blur-md text-white border border-white/20">
                <svg class="size-6" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path clip-rule="evenodd" d="M24 18.4228L42 11.475V34.3663C42 34.7796 41.7457 35.1504 41.3601 35.2992L24 42V18.4228Z" fill="#ffffff" fill-rule="evenodd"></path>
                    <path clip-rule="evenodd" d="M24 8.18819L33.4123 11.574L24 15.2071L14.5877 11.574L24 8.18819ZM9 15.8487L21 20.4805V37.6263L9 32.9945V15.8487ZM27 37.6263V20.4805L39 15.8487V32.9945L27 37.6263ZM25.354 2.29885C24.4788 1.98402 23.5212 1.98402 22.646 2.29885L4.98454 8.65208C3.7939 9.08038 3 10.2097 3 11.475V34.3663C3 36.0196 4.01719 37.5026 5.55962 38.098L22.9197 44.7987C23.6149 45.0671 24.3851 45.0671 25.0803 44.7987L42.4404 38.098C43.9828 37.5026 45 36.0196 45 34.3663V11.475C45 10.2097 44.2061 9.08038 43.0155 8.65208L25.354 2.29885Z" fill="currentColor" fill-rule="evenodd"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-white drop-shadow-md">FEvents</h2>
        </div>

        @* Bottom text *@
        <div class="relative z-10 p-12 max-w-2xl">
            <div class="flex items-center justify-center size-14 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 mb-6">
                <span class="material-symbols-outlined text-white text-3xl">mark_email_unread</span>
            </div>
            <h1 class="text-5xl font-black text-white mb-4 leading-tight tracking-tight drop-shadow-xl">
                Khôi Phục Quyền Truy Cập.
            </h1>
            <p class="text-lg text-white/90 font-medium max-w-md leading-relaxed drop-shadow-lg">
                Đừng lo lắng — chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu đến email FPT của bạn ngay lập tức.
            </p>
            <div class="mt-8 space-y-3">
                <div class="flex items-center gap-3 text-white/80 text-sm font-medium">
                    <div class="flex items-center justify-center size-7 rounded-full bg-white/10 border border-white/20 text-xs font-bold text-white">1</div>
                    Nhập email FPT của bạn
                </div>
                <div class="flex items-center gap-3 text-white/80 text-sm font-medium">
                    <div class="flex items-center justify-center size-7 rounded-full bg-white/10 border border-white/20 text-xs font-bold text-white">2</div>
                    Kiểm tra hộp thư đến
                </div>
                <div class="flex items-center gap-3 text-white/80 text-sm font-medium">
                    <div class="flex items-center justify-center size-7 rounded-full bg-white/10 border border-white/20 text-xs font-bold text-white">3</div>
                    Nhấp vào link và đặt mật khẩu mới
                </div>
            </div>
        </div>
    </div>

    @* Right form panel *@
    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center p-6 sm:p-12 xl:p-24 bg-white">
        <div class="w-full max-w-md space-y-8">

            <div class="lg:hidden flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-3xl">event_upcoming</span>
                <span class="text-2xl font-black tracking-tight text-gray-900">FEvents</span>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="text-center space-y-6">
                    <div class="flex items-center justify-center mx-auto size-20 rounded-2xl bg-green-50 border border-green-100">
                        <span class="material-symbols-outlined text-green-500 text-4xl filled-icon">mark_email_read</span>
                    </div>
                    <div class="space-y-2">
                        <h2 class="text-3xl font-black tracking-tighter text-gray-900">Email Đã Gửi!</h2>
                        <p class="text-gray-500 font-medium leading-relaxed">
                            Hướng dẫn đặt lại mật khẩu đã được gửi đến email của bạn. Vui lòng kiểm tra hộp thư đến.
                        </p>
                    </div>
                    <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 flex items-start gap-3 text-left">
                        <span class="material-symbols-outlined text-amber-500 text-xl mt-0.5">info</span>
                        <p class="text-sm text-amber-700 font-medium">
                            Link đặt lại mật khẩu sẽ hết hạn sau <strong>15 phút</strong>. Hãy kiểm tra cả thư mục spam nếu không thấy email.
                        </p>
                    </div>
                    <a asp-page="/Authentications/Login"
                       class="inline-flex items-center justify-center gap-2 w-full py-4 px-6 bg-primary hover:bg-primary-hover text-white font-bold rounded-xl shadow-primary hover:-translate-y-0.5 transition-all duration-200 active:scale-[0.98]">
                        <span class="material-symbols-outlined text-xl">login</span>
                        Quay Lại Đăng Nhập
                    </a>
                </div>
            }
            else
            {
                <div class="space-y-2">
                    <div class="flex items-center justify-center size-12 rounded-xl bg-primary/10 text-primary mb-2">
                        <span class="material-symbols-outlined text-2xl">lock_reset</span>
                    </div>
                    <h2 class="text-3xl font-black tracking-tighter text-gray-900">Quên Mật Khẩu?</h2>
                    <p class="text-gray-500 font-medium">Nhập email FPT và chúng tôi sẽ gửi link đặt lại mật khẩu.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm font-medium">
                        <span class="material-symbols-outlined text-red-500 text-xl mt-0.5">error</span>
                        <div>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    </div>
                }

                <form method="post" class="space-y-5">

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Email FPT</label>
                        <div class="relative flex items-center rounded-xl border border-gray-300 bg-gray-50 focus-within:ring-2 focus-within:ring-primary/20 focus-within:border-primary transition-all">
                            <span class="material-symbols-outlined text-gray-400 text-xl ml-4">mail</span>
                            <input asp-for="Input.Email"
                                   class="flex-1 h-12 bg-transparent text-gray-900 placeholder:text-gray-400 focus:outline-none font-medium text-sm px-3"
                                   placeholder="ten@fpt.edu.vn" type="email" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-xs text-destructive mt-1 block"></span>
                        <p class="text-xs text-gray-400 ml-1">Chỉ chấp nhận email có đuôi <strong>@@fpt.edu.vn</strong></p>
                    </div>

                    <button type="submit"
                            class="w-full py-4 px-6 bg-primary hover:bg-primary-hover text-white font-bold rounded-xl shadow-primary hover:-translate-y-0.5 transition-all duration-200 active:scale-[0.98] flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-xl">send</span>
                        Gửi Link Đặt Lại Mật Khẩu
                    </button>

                </form>

                <div class="text-center pt-2">
                    <a asp-page="/Authentications/Login"
                       class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined text-base">arrow_back</span>
                        Quay lại đăng nhập
                    </a>
                </div>
            }

        </div>
    </div>
</div>
