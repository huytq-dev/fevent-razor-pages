@page "/reset-password"
@model UI.ResetPasswordModel
@{
    ViewData["Title"] = "FEvents - Đặt Lại Mật Khẩu";
    Layout = "~/Pages/Shared/Authentications/_AuthLayout.cshtml";
}

<div class="flex min-h-screen w-full items-center justify-center bg-white p-6">
    <div class="w-full max-w-md">
        @if (!Model.TokenValid)
        {
            <div class="text-center">
                <div class="mx-auto mb-6 flex size-20 items-center justify-center rounded-full bg-red-100">
                    <span class="material-symbols-outlined text-5xl text-red-600">error</span>
                </div>
                <h1 class="mb-2 text-2xl font-black text-gray-900">Link không hợp lệ</h1>
                <p class="mb-8 text-gray-600">Link đặt lại mật khẩu không đúng hoặc đã hết hạn. Vui lòng yêu cầu gửi lại.</p>
                <a asp-page="/Authentications/ForgotPassword"
                   class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-6 py-4 font-bold text-white transition-colors hover:opacity-90">
                    Gửi lại link đặt mật khẩu
                </a>
            </div>
        }
        else
        {
            <div class="space-y-6">
                <div class="text-center">
                    <div class="mx-auto mb-4 flex size-14 items-center justify-center rounded-xl bg-primary/10 text-primary">
                        <span class="material-symbols-outlined text-3xl">lock_reset</span>
                    </div>
                    <h1 class="text-2xl font-black text-gray-900">Đặt mật khẩu mới</h1>
                    <p class="mt-2 text-gray-500">Nhập mật khẩu mới cho tài khoản của bạn.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
                        <span class="material-symbols-outlined mt-0.5 text-xl text-red-500">error</span>
                        <div>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    </div>
                }

                <form method="post" class="space-y-5">
                    <input asp-for="Input.Token" type="hidden" />

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wide text-gray-700" asp-for="Input.NewPassword">Mật khẩu mới</label>
                        <input asp-for="Input.NewPassword"
                               class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                               placeholder="Nhập mật khẩu mới" type="password" />
                        <span asp-validation-for="Input.NewPassword" class="text-xs text-red-500"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wide text-gray-700" asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                        <input asp-for="Input.ConfirmPassword"
                               class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                               placeholder="Nhập lại mật khẩu mới" type="password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500"></span>
                    </div>

                    <button type="submit"
                            class="w-full rounded-xl bg-primary px-6 py-4 font-bold text-white transition-colors hover:opacity-90">
                        Đặt lại mật khẩu
                    </button>
                </form>

                <div class="text-center">
                    <a asp-page="/Authentications/Login" class="text-sm font-medium text-gray-500 transition-colors hover:text-primary">
                        Quay lại đăng nhập
                    </a>
                </div>
            </div>
        }
    </div>
</div>
