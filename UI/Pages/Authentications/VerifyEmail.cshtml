@page "/verify-email"
@model UI.VerifyEmailModel
@{
    ViewData["Title"] = Model.IsSuccess ? "Xác thực thành công" : "Xác thực thất bại";
    Layout = "~/Pages/Shared/Authentications/_AuthLayout.cshtml";
}

<div class="flex min-h-screen w-full items-center justify-center bg-white p-6">
    <div class="w-full max-w-md text-center">
        @if (Model.IsSuccess)
        {
            <div class="mx-auto mb-6 flex size-20 items-center justify-center rounded-full bg-green-100">
                <span class="material-symbols-outlined text-5xl text-green-600">check_circle</span>
            </div>
            <h1 class="mb-2 text-2xl font-black text-gray-900">Xác thực thành công!</h1>
            <p class="mb-8 text-gray-600">@Model.Message</p>
            <a asp-page="/Authentications/Login"
               class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-6 py-4 font-bold text-white transition-colors hover:opacity-90">
                Đăng nhập ngay
            </a>
        }
        else
        {
            <div class="mx-auto mb-6 flex size-20 items-center justify-center rounded-full bg-red-100">
                <span class="material-symbols-outlined text-5xl text-red-600">error</span>
            </div>
            <h1 class="mb-2 text-2xl font-black text-gray-900">Xác thực thất bại</h1>
            <p class="mb-8 text-gray-600">@Model.Message</p>
            <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
                <a asp-page="/Authentications/Login"
                   class="inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-6 py-4 font-bold text-gray-700 transition-colors hover:bg-gray-50">
                    Về trang đăng nhập
                </a>
                <a asp-page="/Authentications/SignUp"
                   class="inline-flex items-center justify-center rounded-xl bg-primary px-6 py-4 font-bold text-white transition-colors hover:opacity-90">
                    Đăng ký lại
                </a>
            </div>
        }
    </div>
</div>
