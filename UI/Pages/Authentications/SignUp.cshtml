@page "/register"
@model UI.SignUpModel
@{
    ViewData["Title"] = "FEvents - Đăng Ký";
    Layout = "~/Pages/Shared/Authentications/_AuthLayout.cshtml";
}

<div class="flex h-screen w-full">

    <div class="hidden lg:flex relative w-1/2 bg-gray-900 items-end justify-start overflow-hidden group">
        <img alt="Khuôn viên Đại học FPT"
             class="absolute inset-0 w-full h-full object-cover object-center opacity-90 transition-transform duration-1000 group-hover:scale-105"
             src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqNNUcMI7LMQ1X2T-nZNvE7gyO_yfhDxg1V6HKyA078xR1CLu-7bYi6Ljt67J5bPqonYfuHu59rwNY3vLuNgHcE2nB7jITXrWeXtnAcxmJEJpCKcroMAosTrea_3Tvy3J5jXCGnbMi5vr5KqRjN0KtnhmcPqxYTpCqXi_JLGTcM6kMaFKSy1_NSJQgDUoOoSmYHSFiTZnI4LGWBYGsOwzoIb1wBeKP71QCAGj0yZucoC_YuJv3RCU2y1WCw20-DGjAEQbpEjdSB3_v" />
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/90 via-primary/40 to-transparent mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80"></div>
        <div class="absolute top-10 left-10 flex items-center gap-3 z-20">
            <div class="flex items-center justify-center size-10 rounded-lg bg-white/10 backdrop-blur-md text-white border border-white/20">
                <svg class="size-6" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path clip-rule="evenodd" d="M24 18.4228L42 11.475V34.3663C42 34.7796 41.7457 35.1504 41.3601 35.2992L24 42V18.4228Z" fill="#ffffff" fill-rule="evenodd"></path>
                    <path clip-rule="evenodd" d="M24 8.18819L33.4123 11.574L24 15.2071L14.5877 11.574L24 8.18819ZM9 15.8487L21 20.4805V37.6263L9 32.9945V15.8487ZM27 37.6263V20.4805L39 15.8487V32.9945L27 37.6263ZM25.354 2.29885C24.4788 1.98402 23.5212 1.98402 22.646 2.29885L4.98454 8.65208C3.7939 9.08038 3 10.2097 3 11.475V34.3663C3 36.0196 4.01719 37.5026 5.55962 38.098L22.9197 44.7987C23.6149 45.0671 24.3851 45.0671 25.0803 44.7987L42.4404 38.098C43.9828 37.5026 45 36.0196 45 34.3663V11.475C45 10.2097 44.2061 9.08038 43.0155 8.65208L25.354 2.29885Z" fill="currentColor" fill-rule="evenodd"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-white drop-shadow-md">FEvents</h2>
        </div>
        <div class="relative z-10 p-12 max-w-2xl">
            <h1 class="text-5xl font-black text-white mb-4 leading-tight tracking-tight drop-shadow-xl">
                Bắt Đầu Hành Trình.
            </h1>
            <p class="text-lg text-white/90 font-medium max-w-md leading-relaxed drop-shadow-lg">
                Tham gia nền tảng sự kiện chính thức của Đại học FPT. Tạo, khám phá và kết nối với cộng đồng sinh viên.
            </p>
        </div>
    </div>

    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center p-6 sm:p-12 xl:p-24 bg-white overflow-y-auto custom-scrollbar">
        <div class="w-full max-w-lg space-y-8">

            <div class="space-y-2">
                <h2 class="text-3xl font-black tracking-tighter text-foreground">Tạo Tài Khoản</h2>
                <p class="text-muted-foreground font-medium">Vui lòng nhập thông tin để đăng ký.</p>
            </div>

            <form method="post" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Họ và Tên</label>
                        <input asp-for="Input.Fullname"
                               class="w-full h-12 rounded-xl border border-border bg-gray-50 text-foreground placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-sm px-4"
                               placeholder="Nguyễn Văn A" type="text" />
                        <span asp-validation-for="Input.Fullname" class="text-xs text-destructive mt-1 block"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Mã Số Sinh Viên (MSSV)</label>
                        <input asp-for="Input.StudentId"
                               class="w-full h-12 rounded-xl border border-border bg-gray-50 text-foreground placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-sm px-4"
                               placeholder="SE123456" type="text" />
                        <span asp-validation-for="Input.StudentId" class="text-xs text-destructive mt-1 block"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Chuyên Ngành</label>
                        <div class="relative">
                            <select asp-for="Input.Major"
                                    class="w-full h-12 rounded-xl border border-border bg-gray-50 text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-sm appearance-none px-4 cursor-pointer">
                                <option disabled selected value="">Chọn Chuyên Ngành</option>
                                <option value="Software Engineering">Kỹ Thuật Phần Mềm</option>
                                <option value="Artificial Intelligence">Trí Tuệ Nhân Tạo</option>
                                <option value="Graphic Design">Thiết Kế Đồ Họa</option>
                                <option value="International Business">Kinh Doanh Quốc Tế</option>
                                <option value="Digital Marketing">Marketing Kỹ Thuật Số</option>
                                <option value="Information Assurance">An Toàn Thông Tin</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xl">expand_more</span>
                        </div>
                        <span asp-validation-for="Input.Major" class="text-xs text-destructive mt-1 block"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Email FPT</label>
                        <input asp-for="Input.Email"
                               class="w-full h-12 rounded-xl border border-border bg-gray-50 text-foreground placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-sm px-4"
                               placeholder="ten@fpt.edu.vn" type="email" />
                        <span asp-validation-for="Input.Email" class="text-xs text-destructive mt-1 block"></span>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-gray-700 uppercase tracking-wide ml-1">Mật Khẩu</label>
                    <div class="relative">
                        <input asp-for="Input.Password" id="passwordInput"
                               class="w-full h-12 rounded-xl border border-border bg-gray-50 text-foreground placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-sm px-4 pr-12"
                               placeholder="Tạo mật khẩu mạnh" type="password" />
                        <button id="togglePasswordBtn" type="button"
                                class="absolute right-3 top-1/2 -translate-y-1/2 p-1 text-gray-400 hover:text-primary transition-colors rounded-full hover:bg-primary-muted">
                            <span class="material-symbols-outlined text-xl leading-none" id="togglePasswordIcon">visibility_off</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-xs text-destructive mt-1 block"></span>

                    <div class="flex items-center gap-1.5 pt-1 px-1">
                        <div id="strengthBar1" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <div id="strengthBar2" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <div id="strengthBar3" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <div id="strengthBar4" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors duration-300"></div>
                        <span id="strengthText" class="text-[10px] font-bold text-gray-400 ml-1 uppercase tracking-wider">YẾU</span>
                    </div>
                </div>

                @* <div class="flex flex-col gap-1">
                    <div class="flex items-start gap-3">
                        <input asp-for="AgreeTerms" id="terms"
                               class="mt-1 h-4 w-4 rounded border-border text-primary focus:ring-primary/20 cursor-pointer" type="checkbox" />
                        <label class="text-xs text-muted-foreground leading-relaxed cursor-pointer select-none" for="terms">
                            Tôi đồng ý với <a class="text-primary hover:underline font-bold" href="#">Điều Khoản Dịch Vụ</a>
                            và <a class="text-primary hover:underline font-bold" href="#">Chính Sách Bảo Mật</a> của FEvents.
                        </label>
                    </div>
                    <span asp-validation-for="AgreeTerms" class="text-xs text-destructive block"></span>
                </div> *@

                <button type="submit"
                        class="w-full py-4 px-6 bg-primary hover:bg-primary-hover text-white font-bold rounded-xl shadow-primary hover:-translate-y-0.5 transition-all duration-200 active:scale-[0.98]">
                    Đăng Ký
                </button>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-100 border border-red-400 text-destructive px-4 py-2 rounded-xl mt-2 font-medium text-sm">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }
            </form>

            <div class="text-center pt-2">
                <p class="text-sm font-medium text-muted-foreground">
                    Đã có tài khoản?
                    <a asp-page="/Authentications/Login" class="text-primary hover:text-primary-hover font-bold transition-colors ml-1">Đăng Nhập</a>
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const passwordInput = document.getElementById("passwordInput");
            const toggleIcon    = document.getElementById("togglePasswordIcon");
            const bars          = ["strengthBar1","strengthBar2","strengthBar3","strengthBar4"].map(id => document.getElementById(id));
            const strengthText  = document.getElementById("strengthText");

            const conditions = [
                { regex: /.{8,}/,        label: "Ít nhất 8 ký tự" },
                { regex: /[A-Z]/,        label: "Chữ hoa" },
                { regex: /[a-z]/,        label: "Chữ thường" },
                { regex: /\d/,           label: "Chữ số" },
                { regex: /[^A-Za-z0-9]/, label: "Ký tự đặc biệt" }
            ];

            const condList = document.createElement("ul");
            condList.className = "text-xs mt-2 mb-1 font-medium";
            passwordInput.closest(".space-y-1\\.5").appendChild(condList);

            document.getElementById("togglePasswordBtn").addEventListener("click", function () {
                const isPassword = passwordInput.type === "password";
                passwordInput.type     = isPassword ? "text" : "password";
                toggleIcon.textContent = isPassword ? "visibility_off" : "visibility";
            });

            function updateStrength(password) {
                const met      = conditions.map(c => c.regex.test(password));
                const strength = met.filter(Boolean).length;

                const colorMap = { 0: "bg-gray-200", 1: "bg-red-400", 2: "bg-red-400", 3: "bg-yellow-400", 4: "bg-blue-400", 5: "bg-green-500" };
                const textMap  = {
                    0: ["YẾU",       "text-gray-400"],
                    1: ["YẾU",       "text-red-400"],
                    2: ["YẾU",       "text-red-400"],
                    3: ["TRUNG BÌNH","text-yellow-400"],
                    4: ["KHÁ",       "text-blue-400"],
                    5: ["MẠNH",      "text-green-500"]
                };

                bars.forEach((bar, i) => {
                    bar.className = `h-1 flex-1 rounded-full transition-colors duration-300 ${i < strength ? colorMap[strength] : "bg-gray-200"}`;
                });

                const [label, color] = textMap[strength];
                strengthText.textContent = label;
                strengthText.className   = `text-[10px] font-bold ml-1 uppercase tracking-wider transition-colors duration-300 ${color}`;

                condList.innerHTML = conditions.map((c, i) =>
                    `<li class="mb-1 flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs ${met[i] ? "text-green-500" : "text-gray-400"}">${met[i] ? "check_circle" : "cancel"}</span>
                        ${c.label}
                    </li>`
                ).join("");
            }

            passwordInput.addEventListener("input", () => updateStrength(passwordInput.value));
            updateStrength("");
        });
    </script>
}
