@page
@model UI.Pages.Admin.UserManagerModel
@{
    Layout = "~/Pages/Shared/Home/_HomeLayout.cshtml";
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="w-full max-w-[1440px] mx-auto px-4 md:px-10 lg:px-40 py-8">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 shadow-sm border border-green-100">
            <span class="font-medium">Thành công!</span> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 shadow-sm border border-red-100">
            <span class="font-medium">Lỗi!</span> @TempData["ErrorMessage"]
        </div>
    }

    <!-- Breadcrumbs -->
    <nav class="flex text-sm font-medium text-[#8c715f] mb-4" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="/Home/Index" class="hover:text-primary transition-colors">Home</a>
            </li>
            <li>
                <div class="flex items-center">
                    <span class="mx-2 text-gray-400">/</span>
                    <span class="text-[#181411] font-semibold">User Management</span>
                </div>
            </li>
        </ol>
    </nav>

    <!-- Page Heading -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex flex-col gap-2">
            <h1 class="text-[#181411] text-5xl font-black tracking-tight leading-tight">User Management</h1>
            <p class="text-[#8c715f] text-base font-normal max-w-2xl leading-relaxed">
                Manage student, organizer, and admin accounts. View details, update roles, and monitor status across FPT University.
            </p>
        </div>
        <button class="flex items-center justify-center rounded-full h-14 px-8 bg-primary hover:bg-orange-600 text-white text-lg font-bold transition-all shadow-xl shadow-orange-500/30 active:scale-95 whitespace-nowrap shrink-0">
            <span class="material-symbols-outlined mr-2 font-bold">add</span>
            <span>Add New User</span>
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="flex flex-col gap-4 rounded-2xl bg-white p-8 shadow-sm border border-[#e6dfdb] transition-transform hover:scale-[1.01]">
            <div class="flex items-center gap-3">
                <div class="p-2.5 bg-blue-50 rounded-xl text-blue-600">
                    <span class="material-symbols-outlined text-2xl">group</span>
                </div>
                <p class="text-[#8c715f] text-base font-medium">Total Users</p>
            </div>
            <p class="text-[#181411] text-4xl font-black">@Model.TotalUsersCount</p>
        </div>
        <div class="flex flex-col gap-4 rounded-2xl bg-white p-8 shadow-sm border border-[#e6dfdb] transition-transform hover:scale-[1.01]">
            <div class="flex items-center gap-3">
                <div class="p-2.5 bg-orange-50 rounded-xl text-orange-600">
                    <span class="material-symbols-outlined text-2xl">stars</span>
                </div>
                <p class="text-[#8c715f] text-base font-medium">Active Organizers</p>
            </div>
            <p class="text-[#181411] text-4xl font-black">@Model.ActiveOrganizersCount</p>
        </div>
        <div class="flex flex-col gap-4 rounded-2xl bg-white p-8 shadow-sm border border-[#e6dfdb] transition-transform hover:scale-[1.01]">
            <div class="flex items-center gap-3">
                <div class="p-2.5 bg-purple-50 rounded-xl text-purple-600">
                    <span class="material-symbols-outlined text-2xl">person_add</span>
                </div>
                <p class="text-[#8c715f] text-base font-medium">Banned Users</p>
            </div>
            <p class="text-[#181411] text-4xl font-black">@Model.BannedUsersCount</p>
        </div>
    </div>

    <!-- Toolbar & Filter -->
    <div class="mb-8">
        <form method="get" class="relative w-full max-w-xl">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-gray-400">search</span>
            </div>
            <input name="searchTerm" value="@Model.SearchTerm" class="block w-full pl-14 pr-6 py-4 border border-[#e6dfdb] rounded-full bg-white text-[#181411] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/20 text-base shadow-sm" placeholder="Search by name, email, or ID..." type="text" />
        </form>
    </div>

    <!-- Master Table -->
    <div class="bg-white rounded-2xl border border-[#e6dfdb] overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-[#f8f7f5] border-b border-[#e6dfdb]">
                        <th class="py-5 px-8 text-xs font-bold text-gray-500 uppercase tracking-widest">User</th>
                        <th class="py-5 px-8 text-xs font-bold text-gray-500 uppercase tracking-widest text-center">Role</th>
                        <th class="py-5 px-8 text-xs font-bold text-gray-500 uppercase tracking-widest hidden md:table-cell">Department</th>
                        <th class="py-5 px-8 text-xs font-bold text-gray-500 uppercase tracking-widest text-center">Status</th>
                        <th class="py-5 px-8 text-xs font-bold text-gray-500 uppercase tracking-widest text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#e6dfdb]">
                    @foreach (var user in Model.Users)
                    {
                        var currentRole = user.UserRoles.FirstOrDefault()?.Role;
                        var roleName = currentRole?.RoleName ?? "Student";
                        var avatarUrl = string.IsNullOrEmpty(user.AvatarUrl) 
                            ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(user.FullName)}&background=f96706&color=fff" 
                            : user.AvatarUrl;

                        var roleColor = roleName == "Admin" ? "bg-purple-100 text-purple-800 border-purple-200" :
                                        roleName == "Organizer" ? "bg-orange-100 text-orange-800 border-orange-200" :
                                        "bg-blue-100 text-blue-800 border-blue-200";

                        <tr class="hover:bg-gray-50/80 transition-colors group">
                            <td class="py-6 px-8 whitespace-nowrap">
                                <div class="flex items-center gap-4">
                                    <div class="h-12 w-12 rounded-full bg-cover bg-center shrink-0 border-2 border-white shadow-sm" style='background-image: url("@avatarUrl");'></div>
                                    <div class="flex flex-col">
                                        <span class="text-base font-bold text-[#181411]">@user.FullName</span>
                                        <span class="text-sm text-gray-500">@user.Email</span>
                                    </div>
                                </div>
                            </td>
                            
                            <td class="py-6 px-8 whitespace-nowrap text-center">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold @roleColor border shadow-sm">
                                    @roleName
                                </span>
                            </td>
                            
                            <td class="py-6 px-8 whitespace-nowrap hidden md:table-cell">
                                <span class="text-base text-gray-700 font-medium">@(user.Major ?? "N/A")</span>
                            </td>
                            
                            <td class="py-6 px-8 whitespace-nowrap text-center">
                                @if (user.IsDeleted)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-red-50 text-red-700 border border-red-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-600"></span> Suspended
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-green-50 text-green-700 border border-green-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span> Active
                                    </span>
                                }
                            </td>
                            
                            <td class="py-6 px-8 whitespace-nowrap text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <!-- Change Role Dropdown -->
                                    <form method="post" asp-page-handler="ChangeRole" class="inline-block relative">
                                        <input type="hidden" name="UserId" value="@user.Id" />
                                        <select name="NewRoleId" onchange="this.form.submit()" class="text-sm rounded-xl border-[#e6dfdb] focus:ring-primary/20 focus:border-primary px-4 py-2 bg-white cursor-pointer shadow-sm hover:border-primary transition-all pr-10 appearance-none">
                                            <option disabled selected hidden>Change Role</option>
                                            @foreach (var role in Model.AvailableRoles)
                                            {
                                                if (currentRole?.Id == role.Id) continue;
                                                <option value="@role.Id">Set @role.RoleName</option>
                                            }
                                        </select>
                                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-lg">expand_more</span>
                                    </form>
                                    
                                    <!-- Ban/Unban -->
                                    <form method="post" asp-page-handler="ToggleBan" class="inline-block" onsubmit="return confirm('Bạn có chắc chắn muốn thực hiện hành động này?');">
                                        <input type="hidden" name="UserId" value="@user.Id" />
                                        @if (user.IsDeleted)
                                        {
                                            <button type="submit" class="h-10 w-10 flex items-center justify-center rounded-xl bg-green-50 text-green-600 hover:bg-green-600 hover:text-white transition-all shadow-sm" title="Unban User">
                                                <span class="material-symbols-outlined">how_to_reg</span>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="h-10 w-10 flex items-center justify-center rounded-xl bg-gray-50 text-gray-400 hover:bg-red-600 hover:text-white transition-all shadow-sm" title="Ban User">
                                                <span class="material-symbols-outlined">block</span>
                                            </button>
                                        }
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    
                    @if(!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-20 text-center flex flex-col items-center justify-center gap-4">
                                <span class="material-symbols-outlined text-6xl text-gray-200">person_search</span>
                                <p class="text-gray-500 text-lg font-medium">Không tìm thấy người dùng nào phù hợp.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
