@page
@using Microsoft.AspNetCore.Http
@model UI.Pages.Profile.ViewProfileModel
@{
    ViewData["Title"] = "Xem Profile Sinh Viên";
    var roleName = HttpContext.Session.GetString("RoleName");
    Layout = roleName == "Admin"     ? "~/Pages/Shared/Admin/_AdminLayout.cshtml"
           : roleName == "Organizer" ? "~/Pages/Shared/Management/_ManagementLayout.cshtml"
           : "~/Pages/Shared/Home/_HomeLayout.cshtml";
    var student = Model.Student;
    var avatarUrl = string.IsNullOrEmpty(student?.AvatarUrl)
        ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(student?.FullName ?? "Student")}&background=f96706&color=fff"
        : student.AvatarUrl;
}
<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
    <!-- Main Content Area -->
    <main class="flex-grow w-full px-4 sm:px-6 lg:px-8 py-8 flex justify-center">
        <div class="w-full max-w-4xl flex flex-col gap-6">
            <!-- Profile Header Card -->
            <div class="bg-white rounded-xl shadow-sm border border-[#e6dfdb] overflow-hidden">
                <div class="h-32 bg-gradient-to-r from-primary/10 to-primary/5 w-full relative">
                    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#f96706 1px, transparent 1px); background-size: 20px 20px;"></div>
                </div>
                <div class="px-8 pb-8 -mt-16 flex flex-col items-center relative">
                    <div class="relative group">
                        <div class="size-32 rounded-full border-4 border-white shadow-md bg-cover bg-center bg-no-repeat" data-alt="Student profile picture large" style='background-image: url("@avatarUrl");'>
                        </div>
                    </div>
                    <div class="mt-4 flex flex-col items-center gap-1">
                        <h1 class="text-2xl md:text-3xl font-bold text-[#181411] text-center">@(student?.FullName ?? "Tên sinh viên")</h1>
                        <div class="flex items-center gap-2 mt-1">
                            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-semibold border border-primary/20">@(student?.StudentId ?? "MSSV")</span>
                            <span class="px-3 py-1 rounded-full bg-green-100 text-green-700 text-sm font-medium border border-green-200">@((student?.IsVerified ?? false) ? "Active" : "Inactive")</span>
                        </div>
                        <p class="text-[#8c715f] text-base mt-2">@(student?.Major ?? "Major")</p>
                    </div>
                    <div class="flex gap-3 mt-6 w-full max-w-sm justify-center">
                        <a asp-page="/Profile/UpdateProfile" class="flex-1 flex items-center justify-center gap-2 h-10 px-6 rounded-full bg-primary hover:bg-orange-600 text-white font-medium shadow-sm transition-all text-sm">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                            <span>Edit Profile</span>
                        </a>
                        <button class="flex-1 flex items-center justify-center gap-2 h-10 px-6 rounded-full bg-white border border-[#e6dfdb] text-[#181411] hover:bg-gray-50 font-medium transition-all text-sm">
                            <span class="material-symbols-outlined text-[18px]">lock_reset</span>
                            <span>Change Password</span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="md:col-span-2 bg-white rounded-xl shadow-sm border border-[#e6dfdb] p-6">
                    <div class="flex items-center gap-2 mb-6 border-b border-[#f5f2f0] pb-4">
                        <div class="p-2 rounded-full bg-primary/10 text-primary">
                            <span class="material-symbols-outlined">person_book</span>
                        </div>
                        <h3 class="text-lg font-bold text-[#181411]">Academic Information</h3>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-8">
                        <div class="flex flex-col gap-1">
                            <p class="text-[#8c715f] text-sm font-normal">Major / Specialization</p>
                            <p class="text-[#181411] text-base font-medium">@(student?.Major ?? "Major")</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-[#8c715f] text-sm font-normal">University Email</p>
                            <p class="text-[#181411] text-base font-medium break-all">@(student?.Email ?? "email@fpt.edu.vn")</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-[#8c715f] text-sm font-normal">Current Campus</p>
                            <p class="text-[#181411] text-base font-medium">@(student?.SchoolName ?? "FPT University")</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-[#8c715f] text-sm font-normal">Date of Birth</p>
                            <p class="text-[#181411] text-base font-medium">@(student?.DOB?.ToString("dd/MM/yyyy") ?? "")</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-[#8c715f] text-sm font-normal">Phone Number</p>
                            <p class="text-[#181411] text-base font-medium">@(student?.PhoneNumber ?? "")</p>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-6">
                    <div class="bg-white rounded-xl shadow-sm border border-[#e6dfdb] p-6 h-fit">
                        <div class="flex items-center gap-2 mb-4">
                            <div class="p-2 rounded-full bg-blue-50 text-blue-600">
                                <span class="material-symbols-outlined">share</span>
                            </div>
                            <h3 class="text-lg font-bold text-[#181411]">Social Profiles</h3>
                        </div>
                        <div class="flex flex-col gap-4">
                            <a class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#f5f2f0] transition-colors group" href="#">
                                <div class="size-10 rounded-full bg-[#0077b5]/10 flex items-center justify-center text-[#0077b5]">
                                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                                </div>
                                <div class="flex flex-col">
                                    <span class="text-sm font-medium text-[#181411] group-hover:text-primary transition-colors">LinkedIn</span>
                                    <span class="text-xs text-[#8c715f]">/in/nguyen-van-a</span>
                                </div>
                                <span class="material-symbols-outlined ml-auto text-gray-400 text-sm">open_in_new</span>
                            </a>
                            <a class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#f5f2f0] transition-colors group" href="#">
                                <div class="size-10 rounded-full bg-[#333]/10 flex items-center justify-center text-[#333]">
                                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.42-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
                                </div>
                                <div class="flex flex-col">
                                    <span class="text-sm font-medium text-[#181411] group-hover:text-primary transition-colors">GitHub</span>
                                    <span class="text-xs text-[#8c715f]">@(student?.Username ?? "username")</span>
                                </div>
                                <span class="material-symbols-outlined ml-auto text-gray-400 text-sm">open_in_new</span>
                            </a>
                            <a class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#f5f2f0] transition-colors group" href="#">
                                <div class="size-10 rounded-full bg-[#1877f2]/10 flex items-center justify-center text-[#1877f2]">
                                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                                </div>
                                <div class="flex flex-col">
                                    <span class="text-sm font-medium text-[#181411] group-hover:text-primary transition-colors">Facebook</span>
                                    <span class="text-xs text-[#8c715f]">/nguyenvana</span>
                                </div>
                                <span class="material-symbols-outlined ml-auto text-gray-400 text-sm">open_in_new</span>
                            </a>
                        </div>
                    </div>
                    <div class="bg-gradient-to-br from-primary to-orange-400 rounded-xl shadow-sm p-6 text-white relative overflow-hidden">
                        <div class="absolute -right-6 -top-6 w-24 h-24 rounded-full bg-white/20"></div>
                        <div class="absolute -left-6 -bottom-6 w-20 h-20 rounded-full bg-white/10"></div>
                        <h3 class="text-lg font-bold mb-4 relative z-10">Participation</h3>
                        <div class="flex justify-between items-center relative z-10">
                            <div class="text-center">
                                <p class="text-3xl font-bold">@Model.EventsAttendedCount</p>
                                <p class="text-xs opacity-90 font-light">Events Attended</p>
                            </div>
                            <div class="h-8 w-px bg-white/30"></div>
                            <div class="text-center">
                                <p class="text-3xl font-bold">@Model.ClubsJoinedCount</p>
                                <p class="text-xs opacity-90 font-light">Clubs Joined</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
