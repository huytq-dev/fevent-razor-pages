@page
@model UI.Pages.Profile.UpdateProfileModel
@{
    Layout = "~/Pages/Shared/Home/_HomeLayout.cshtml";
    ViewData["Title"] = "Cập nhật Profile";
    var user = Model.AppUser;
    var avatarUrl = string.IsNullOrEmpty(user?.AvatarUrl)
        ? "https://cdn-icons-png.flaticon.com/512/3177/3177440.png"
        : user.AvatarUrl;
}
<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <main class="flex-grow w-full px-4 sm:px-6 lg:px-8 py-8 flex justify-center">
        <div class="w-full max-w-3xl flex flex-col gap-8">
            <div class="flex flex-col md:flex-row items-center gap-8 border-b border-[#f5f1f0] pb-10">
                <div class="relative group cursor-pointer">
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full w-32 h-32 ring-4 ring-background-light" data-alt="Current large profile picture" style='background-image: url("@avatarUrl");'>
                    </div>
                </div>
                <div class="flex flex-col items-center md:items-start gap-3 flex-1">
                    <div class="text-center md:text-left">
                        <p class="text-[#181211] text-2xl font-bold leading-tight">@(user?.FullName ?? "Tên sinh viên")</p>
                        <p class="text-[#8c695f] text-base">@(user?.StudentId ?? "MSSV") • @(user?.Major ?? "Major")</p>
                    </div>
                </div>
            </div>
            <form method="post" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                                <input type="hidden" asp-for="AppUser.Username" />
                <div class="col-span-1 md:col-span-2">
                    <div asp-validation-summary="All" class="text-red-500 text-sm"></div>
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50" role="alert">
                            <span class="font-medium">Thành công!</span> @TempData["SuccessMessage"]
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
                            <span class="font-medium">Lỗi!</span> @TempData["ErrorMessage"]
                        </div>
                    }
                </div>
                <label class="flex flex-col gap-2">
                    <p class="text-[#181211] text-base font-medium">Full Name</p>
                    <div class="relative">
                        <input asp-for="AppUser.FullName" class="w-full rounded-xl border border-[#e6dddb] bg-white text-[#181211] h-14 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-[#8c695f]" placeholder="Enter your full name" type="text" />
                        <span asp-validation-for="AppUser.FullName" class="text-red-500 text-xs mt-1"></span>
                        @if (ViewData.ModelState["AppUser.FullName"]?.Errors.Count > 0)
                        {
                            foreach (var err in ViewData.ModelState["AppUser.FullName"].Errors)
                            {
                                <span class="text-red-500 text-xs mt-1">@err.ErrorMessage</span>
                            }
                        }
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#8c695f]">person</span>
                    </div>
                </label>
                <label class="flex flex-col gap-2">
                    <div class="flex justify-between">
                        <p class="text-[#181211] text-base font-medium">Student ID</p>
                        <span class="text-xs font-medium text-[#8c695f] bg-[#f5f1f0] px-2 py-0.5 rounded-full">Read-only</span>
                    </div>
                    <input asp-for="AppUser.StudentId" class="w-full rounded-xl border-none bg-[#f5f1f0] text-[#8c695f] h-14 px-4 cursor-not-allowed" readonly type="text" />
                </label>
                <label class="flex flex-col gap-2">
                    <p class="text-[#181211] text-base font-medium">Major</p>
                    <div class="relative">
                        <select asp-for="AppUser.Major" class="w-full rounded-xl border border-[#e6dddb] bg-white text-[#181211] h-14 px-4 appearance-none focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
                            <span asp-validation-for="AppUser.Major" class="text-red-500 text-xs mt-1"></span>
                            <option value="Software Engineering">Software Engineering</option>
                            <option value="Artificial Intelligence">Artificial Intelligence</option>
                            <option value="Graphic Design">Graphic Design</option>
                            <option value="International Business">International Business</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#8c695f] pointer-events-none">expand_more</span>
                    </div>
                </label>
                <label class="flex flex-col gap-2">
                    <div class="flex justify-between">
                        <p class="text-[#181211] text-base font-medium">University Email</p>
                        <span class="text-xs font-medium text-[#8c695f] bg-[#f5f1f0] px-2 py-0.5 rounded-full">Read-only</span>
                    </div>
                    <div class="relative">
                        <input asp-for="AppUser.Email" class="w-full rounded-xl border-none bg-[#f5f1f0] text-[#8c695f] h-14 px-4 cursor-not-allowed" readonly type="email" />
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#8c695f]">lock</span>
                    </div>
                </label>
                <label class="flex flex-col gap-2">
                    <p class="text-[#181211] text-base font-medium">Phone Number</p>
                    <div class="relative">
                        <input asp-for="AppUser.PhoneNumber" class="w-full rounded-xl border border-[#e6dddb] bg-white text-[#181211] h-14 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-[#8c695f]" placeholder="09X XXX XXXX" type="tel" />
                        <span asp-validation-for="AppUser.PhoneNumber" class="text-red-500 text-xs mt-1"></span>
                        @if (ViewData.ModelState["AppUser.PhoneNumber"]?.Errors.Count > 0)
                        {
                            foreach (var err in ViewData.ModelState["AppUser.PhoneNumber"].Errors)
                            {
                                <span class="text-red-500 text-xs mt-1">@err.ErrorMessage</span>
                            }
                        }
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#8c695f]">phone</span>
                    </div>
                </label>
                <label class="flex flex-col gap-2">
                    <p class="text-[#181211] text-base font-medium">Date of Birth</p>
                    <div class="relative">
                        <input asp-for="AppUser.DOB" class="w-full rounded-xl border border-[#e6dddb] bg-white text-[#181211] h-14 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-[#8c695f]" type="date" />
                        <span asp-validation-for="AppUser.DOB" class="text-red-500 text-xs mt-1"></span>
                        @if (ViewData.ModelState["AppUser.DOB"]?.Errors.Count > 0)
                        {
                            foreach (var err in ViewData.ModelState["AppUser.DOB"].Errors)
                            {
                                <span class="text-red-500 text-xs mt-1">@err.ErrorMessage</span>
                            }
                        }
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#8c695f]">calendar_month</span>
                    </div>
                </label>
                <!-- User entity không có trường Bio, bỏ mục này -->
                <div class="flex flex-col-reverse md:flex-row items-center justify-end gap-4 mt-4 pt-6 border-t border-[#f5f1f0] col-span-1 md:col-span-2">
                    <a asp-page="/Profile/ViewProfile" class="w-full md:w-auto min-w-[140px] h-12 rounded-full border border-[#e6dddb] text-[#181211] font-bold hover:bg-[#f5f1f0] transition-colors flex items-center justify-center">
                        Cancel
                    </a>
                    <button type="submit" class="w-full md:w-auto min-w-[180px] h-12 rounded-full bg-primary text-white font-bold shadow-lg shadow-orange-500/30 hover:bg-[#e0481d] hover:shadow-orange-500/50 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-xl">save</span>
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <!-- Flatpickr for better datepicker UI -->
    <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        $(function () {
            $("input[name='AppUser.DOB']").flatpickr({
                dateFormat: "Y-m-d",
                maxDate: "today",
                allowInput: true
            });
        });
    </script>
}
