<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UI</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UI.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col bg-white text-slate-900">
    <header class="border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="container mx-auto flex items-center gap-4 px-4 py-3">
            <a class="text-lg font-semibold tracking-tight" asp-area="" asp-page="/Index">UI</a>
            <nav class="ml-auto flex items-center gap-4 text-sm font-medium">
                <a class="text-slate-600 hover:text-slate-900 transition-colors" asp-area="" asp-page="/Index">Home</a>
                <a class="text-slate-600 hover:text-slate-900 transition-colors" asp-area="" asp-page="/Privacy">Privacy</a>
            </nav>
        </div>
    </header>

    <main role="main" class="flex-1">
        <div class="container mx-auto px-4 py-6">
            @RenderBody()
        </div>
    </main>

    <footer class="border-t border-slate-200 text-sm text-slate-500">
        <div class="container mx-auto px-4 py-6">
            &copy; 2026 - UI - <a class="hover:text-slate-700 transition-colors" asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
