@using Microsoft.AspNetCore.Http
@{
    var fullName  = Context.Session.GetString("FullName");
    var avatarUrl = Context.Session.GetString("AvatarUrl");

    if (string.IsNullOrEmpty(avatarUrl) && !string.IsNullOrEmpty(fullName))
    {
        avatarUrl = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(fullName)}&background=f96706&color=fff";
    }

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<header class="bg-white border-b border-border sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">

            <div class="flex items-center gap-2">
                <a href="/" class="flex items-center gap-2">
                    <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z" />
                    </svg>
                    <span class="font-display font-bold text-xl text-foreground tracking-tight">FEvents</span>
                </a>
            </div>

            <nav class="hidden md:flex space-x-8">
                <a asp-page="/Management/CreateEvent" asp-route-tab="events"
                   class="@(currentPage.Contains("CreateEvent") ? "text-primary font-bold" : "text-foreground hover:text-primary font-medium") transition-colors">
                    My Events
                </a>
                <a asp-page="/Management/CreateEvent" asp-route-tab="create"
                   class="text-foreground hover:text-primary font-medium transition-colors">
                    Create Event
                </a>
            </nav>

            <div class="flex items-center gap-5">
                <div class="relative flex items-center gap-3 cursor-pointer group">
                    <div class="hidden sm:block text-right">
                        <p class="text-sm font-semibold text-foreground leading-tight">@fullName</p>
                        <p class="text-xs text-muted-foreground">Organizer</p>
                    </div>
                    <img class="h-9 w-9 rounded-full object-cover border border-border"
                         src="@avatarUrl"
                         alt="User avatar">

                    <div class="absolute right-0 top-full mt-2 w-48 bg-white rounded-md shadow-lg py-1 border border-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                        <a asp-page="/Profile/ViewProfile" class="block px-4 py-2 text-sm text-foreground hover:bg-gray-100 font-medium whitespace-nowrap">View Profile</a>
                        <hr class="border-border my-1" />
                        <a asp-page="/Authentications/Logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-gray-100 font-medium whitespace-nowrap">Logout</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</header>
